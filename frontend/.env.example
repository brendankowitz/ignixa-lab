# Base URL for the Functions backend. Leave empty to use same-origin relative
# `/api/*` paths (recommended when the SPA is served behind the same host, or
# when using the Vite dev proxy in `vite.config.ts`). Set this to an absolute
# origin (for example https://ignixa-lab.azurewebsites.net) to target a remote
# backend from a standalone build.
#
# In production (the GitHub Pages deployment), the SPA is served from a
# different origin than the Functions app, so this MUST point at the deployed
# Functions app's absolute URL — it is supplied at build time from the
# `VITE_API_BASE_URL` repository variable in `.github/workflows/pages.yml`,
# not from this file.
VITE_API_BASE_URL=
