{
  "resourceType": "TestScript",
  "id": "search-patient-by-id",
  "name": "Patient search by id",
  "status": "active",
  "version": "4.0",
  "description": "Creates a synthetic Patient, then searches Patient?_id={id} and asserts the server returns a searchset Bundle that contains the created resource. Exercises the most basic search parameter supported by every FHIR server.",
  "fixture": [
    {
      "id": "patient-fixture",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "extension": [
          {
            "url": "http://ignixa.io/testscript/fhirfakes",
            "valueCode": "Patient"
          }
        ]
      }
    }
  ],
  "variable": [
    {
      "name": "patientId",
      "sourceId": "create-response",
      "path": "id",
      "description": "The server-assigned id from the create response"
    }
  ],
  "setup": {
    "action": [
      {
        "operation": {
          "type": {
            "code": "create"
          },
          "resource": "Patient",
          "sourceId": "patient-fixture",
          "responseId": "create-response",
          "description": "Create a synthetic Patient to search for"
        }
      }
    ]
  },
  "test": [
    {
      "name": "search by _id returns a searchset Bundle",
      "description": "Patient?_id={id} must return HTTP 200 with a Bundle of type searchset",
      "action": [
        {
          "operation": {
            "type": {
              "code": "search"
            },
            "url": "Patient?_id=${patientId}",
            "responseId": "search-response",
            "description": "Search for the Patient by its id"
          }
        },
        {
          "assert": {
            "description": "Search must return HTTP 200",
            "response": "okay"
          }
        },
        {
          "assert": {
            "description": "Response body must be a Bundle",
            "resource": "Bundle"
          }
        },
        {
          "assert": {
            "description": "Bundle type must be searchset",
            "expression": "Bundle.type",
            "value": "searchset",
            "operator": "equals"
          }
        },
        {
          "assert": {
            "description": "Search results must contain the created Patient",
            "expression": "Bundle.entry.resource.ofType(Patient).id contains '${patientId}'"
          }
        }
      ]
    }
  ],
  "teardown": {
    "action": [
      {
        "operation": {
          "type": {
            "code": "delete"
          },
          "url": "Patient/${patientId}",
          "description": "Teardown: delete the synthetic Patient"
        }
      }
    ]
  }
}
