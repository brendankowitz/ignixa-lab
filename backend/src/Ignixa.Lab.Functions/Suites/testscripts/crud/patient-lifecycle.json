{
  "resourceType": "TestScript",
  "id": "crud-patient-lifecycle",
  "name": "Patient CRUD lifecycle",
  "status": "active",
  "version": "4.0",
  "description": "Create, read, update, and delete lifecycle for a Patient resource. A synthetic Patient is created in setup to obtain a server-assigned id, then exercised through the full lifecycle and cleaned up in teardown.",
  "fixture": [
    {
      "id": "patient-fixture",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "extension": [
          {
            "url": "http://ignixa.io/testscript/fhirfakes",
            "valueCode": "Patient"
          }
        ]
      }
    }
  ],
  "variable": [
    {
      "name": "patientId",
      "sourceId": "create-response",
      "path": "id",
      "description": "The server-assigned id from the create response"
    }
  ],
  "setup": {
    "action": [
      {
        "operation": {
          "type": {
            "code": "create"
          },
          "resource": "Patient",
          "sourceId": "patient-fixture",
          "responseId": "create-response",
          "description": "Create a synthetic Patient to obtain a server-assigned id"
        }
      }
    ]
  },
  "test": [
    {
      "name": "create returns 201 and assigns an id",
      "description": "Server must respond with 201 Created and assign a non-empty id",
      "action": [
        {
          "assert": {
            "description": "Setup create must have returned HTTP 201",
            "sourceId": "create-response",
            "response": "created"
          }
        },
        {
          "assert": {
            "description": "Response body must be a Patient resource",
            "sourceId": "create-response",
            "resource": "Patient"
          }
        },
        {
          "assert": {
            "description": "Server must have assigned an id",
            "sourceId": "create-response",
            "expression": "Patient.id.exists()"
          }
        }
      ]
    },
    {
      "name": "read returns the created resource",
      "description": "GET /Patient/{id} must return the Patient that was just created",
      "action": [
        {
          "operation": {
            "type": {
              "code": "read"
            },
            "url": "Patient/${patientId}",
            "responseId": "read-response",
            "description": "Read the Patient by server-assigned id"
          }
        },
        {
          "assert": {
            "description": "Read must return HTTP 200",
            "response": "okay"
          }
        },
        {
          "assert": {
            "description": "Response body must be a Patient",
            "resource": "Patient"
          }
        },
        {
          "assert": {
            "description": "Returned id must match the one assigned at create",
            "expression": "Patient.id",
            "value": "${patientId}",
            "operator": "equals"
          }
        }
      ]
    },
    {
      "name": "update round-trips the resource",
      "description": "PUT /Patient/{id} must be accepted with a 2xx status",
      "action": [
        {
          "operation": {
            "type": {
              "code": "read"
            },
            "url": "Patient/${patientId}",
            "responseId": "pre-update-read",
            "description": "Fetch current resource to use as the update body"
          }
        },
        {
          "operation": {
            "type": {
              "code": "update"
            },
            "url": "Patient/${patientId}",
            "sourceId": "pre-update-read",
            "responseId": "update-response",
            "description": "PUT the resource back (round-trip update)"
          }
        },
        {
          "assert": {
            "description": "Update must return a success status (2xx)",
            "response": "okay"
          }
        }
      ]
    },
    {
      "name": "delete removes the resource",
      "description": "DELETE /Patient/{id} must return a 2xx status",
      "action": [
        {
          "operation": {
            "type": {
              "code": "delete"
            },
            "url": "Patient/${patientId}",
            "responseId": "delete-response",
            "description": "Delete the Patient resource"
          }
        },
        {
          "assert": {
            "description": "Delete must return a 2xx success status",
            "response": "okay"
          }
        }
      ]
    },
    {
      "name": "read after delete returns 410 or 404",
      "description": "GET after DELETE must return 410 Gone (FHIR R4 behavior) or 404 Not Found",
      "action": [
        {
          "operation": {
            "type": {
              "code": "read"
            },
            "url": "Patient/${patientId}",
            "responseId": "after-delete-read",
            "description": "Attempt to read the deleted Patient"
          }
        },
        {
          "assert": {
            "description": "Primary: expect 410 Gone for a deleted resource",
            "response": "gone",
            "warningOnly": false
          }
        },
        {
          "assert": {
            "description": "Alternative: 404 Not Found is also accepted",
            "response": "notFound",
            "warningOnly": true
          }
        }
      ]
    }
  ],
  "teardown": {
    "action": [
      {
        "operation": {
          "type": {
            "code": "delete"
          },
          "url": "Patient/${patientId}",
          "description": "Teardown: clean up the Patient (may already be deleted)"
        }
      }
    ]
  }
}
