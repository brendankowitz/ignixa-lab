  "test": [
    {
      "name": "$bulk-delete kick-off: system-level, multiple resource types",
      "description": "System-level $bulk-delete kick-off across multiple resource types must return 202 Accepted with a non-empty Content-Location header.",
      "action": [
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|ignixa-bd-basic", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-basic-kickoff", "description": "DELETE $bulk-delete?_tag=http://ignixa.io/testscript/suite/test|ignixa-bd-basic" } },
        { "assert": { "description": "Kick-off must return 202 Accepted", "responseCode": "202" } },
        { "assert": { "description": "Content-Location header must be present and non-empty", "headerField": "Content-Location" } }
      ]
    },
    {
      "name": "$bulk-delete: single best-effort status poll",
      "description": "A single status check on the kicked-off job's Content-Location; warningOnly since the job may finish before or after this check.",
      "action": [
        { "operation": { "type": { "code": "read" }, "method": "GET", "url": "${bulkDeleteBasicLocation}", "responseId": "bulk-delete-basic-poll", "description": "GET the bulk-delete job status URL" } },
        { "assert": { "description": "Status poll should return a 2xx status, either 202 (still running) or 200 (complete) (warningOnly: timing-dependent)", "response": "okay", "warningOnly": true } }
      ]
    },
    {
      "name": "$bulk-delete: invalid search parameter is rejected with 400",
      "description": "An invalid search parameter must be rejected synchronously with 400 before any job is created.",
      "action": [
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|ignixa-bd-badreq&invalidParam=badRequest", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-bad-request", "description": "DELETE $bulk-delete?_tag=...&invalidParam=badRequest" } },
        { "assert": { "description": "Must return HTTP 400", "response": "bad" } }
      ]
    },
    {
      "name": "$bulk-delete kick-off: type-scoped (Organization/$bulk-delete)",
      "description": "Type-scoped $bulk-delete (Organization) kick-off must return 202 Accepted with a Content-Location header.",
      "action": [
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Organization/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|ignixa-bd-typeorg", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-type-scoped-kickoff", "description": "DELETE Organization/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|ignixa-bd-typeorg" } },
        { "assert": { "description": "Type-scoped kick-off must return 202 Accepted", "response": "okay" } },
        { "assert": { "description": "Content-Location header must be present and non-empty", "headerField": "Content-Location" } }
      ]
    },
    {
      "name": "$bulk-delete kick-off accepts hardDelete / purgeHistory / excludedResourceTypes / _include / _revinclude / _remove-references options",
      "description": "Kick-off must accept each optional query parameter (_hardDelete, _purgeHistory, excludedResourceTypes, _include, _revinclude, and _hardDelete+_remove-references together) and return 202 Accepted; resulting deletion counts are not verified.",
      "action": [
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Patient/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|ignixa-bd-hard&_hardDelete=true", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-hard-kickoff", "description": "DELETE Patient/$bulk-delete?_tag=...&_hardDelete=true" } },
        { "assert": { "description": "_hardDelete=true kick-off must return 202 Accepted", "sourceId": "bulk-delete-hard-kickoff", "response": "okay" } },
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Patient/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|ignixa-bd-purge&_purgeHistory=true", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-purge-kickoff", "description": "DELETE Patient/$bulk-delete?_tag=...&_purgeHistory=true" } },
        { "assert": { "description": "_purgeHistory=true kick-off must return 202 Accepted", "sourceId": "bulk-delete-purge-kickoff", "response": "okay" } },
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|ignixa-bd-excl&excludedResourceTypes=Observation", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-excluded-kickoff", "description": "DELETE $bulk-delete?_tag=...&excludedResourceTypes=Observation" } },
        { "assert": { "description": "excludedResourceTypes kick-off must return 202 Accepted", "sourceId": "bulk-delete-excluded-kickoff", "response": "okay" } },
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Observation/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|ignixa-bd-incl&_include=Observation:*", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-include-kickoff", "description": "DELETE Observation/$bulk-delete?_tag=...&_include=Observation:*" } },
        { "assert": { "description": "_include kick-off must return 202 Accepted", "sourceId": "bulk-delete-include-kickoff", "response": "okay" } },
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Patient/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|ignixa-bd-revincl&_revinclude=*:*", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-revinclude-kickoff", "description": "DELETE Patient/$bulk-delete?_tag=...&_revinclude=*:*" } },
        { "assert": { "description": "_revinclude kick-off must return 202 Accepted", "sourceId": "bulk-delete-revinclude-kickoff", "response": "okay" } },
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Patient/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|ignixa-bd-remref&_hardDelete=true&_remove-references=true", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-remove-references-kickoff", "description": "DELETE Patient/$bulk-delete?_tag=...&_hardDelete=true&_remove-references=true" } },
        { "assert": { "description": "_remove-references kick-off must return 202 Accepted", "sourceId": "bulk-delete-remove-references-kickoff", "response": "okay" } }
      ]
    }
  ],
  "teardown": {
    "action": [
      { "operation": { "type": { "code": "delete" }, "url": "Patient/ignixa-bd-basic-pat1", "description": "Teardown (defensive, in case the async job had not yet deleted it): delete basic-pat1" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/ignixa-bd-basic-pat2", "description": "Teardown (defensive): delete basic-pat2" } },
