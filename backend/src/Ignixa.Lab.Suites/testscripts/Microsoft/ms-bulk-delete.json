      { "operation": { "type": { "code": "delete" }, "url": "Patient/ignixa-bd-purge-pat1", "description": "Teardown (defensive): delete purge-pat1" } },
      { "operation": { "type": { "code": "delete" }, "url": "Observation/ignixa-bd-excl-obs1", "description": "Teardown (defensive): delete excl-obs1" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/ignixa-bd-excl-pat1", "description": "Teardown (defensive): delete excl-pat1" } },
      { "operation": { "type": { "code": "delete" }, "url": "Observation/ignixa-bd-incl-obs1", "description": "Teardown (defensive): delete incl-obs1" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/ignixa-bd-incl-pat1", "description": "Teardown (defensive): delete incl-pat1" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/ignixa-bd-revincl-pat1", "description": "Teardown (defensive): delete revincl-pat1" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/ignixa-bd-remref-pat1", "description": "Teardown (defensive): delete remref-pat1" } }
    ]
  }
