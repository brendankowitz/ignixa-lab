{
  "resourceType": "TestScript",
  "name": "Operations/everything-operation",
  "description": "Patient $everything conformance tests ported from fhir-server EverythingOperationTests. Uses client-supplied IDs (PUT) so cross-references (managingOrganization, subject, participant.actor) resolve statically. Organization fhir262-evx-org; Patient fhir262-evx-pat (managingOrganization=org) with compartment members Observation fhir262-evx-obs, Condition fhir262-evx-cond, Appointment fhir262-evx-appt; a decoy Patient fhir262-evx-other with its own Observation fhir262-evx-other-obs proves $everything never leaks cross-patient content. APPROXIMATION: the source fixture also exercises Device/DeviceAssociation compartment membership and Encounter, but Device<->Patient linkage differs by FHIR version (R4 Device.patient, R4B Device.subject, R5+ separate DeviceAssociation resource) and Encounter.class differs (single Coding in R4/R4B vs List<CodeableConcept> in R5), neither of which can be expressed as one static fixture valid across '4.0,4.3,5.0' — both are skipped here; Condition is used in place of Encounter as a version-stable compartment member. The engine has no loop/next-link-following construct, and fhir-server's own tests show $everything can return compartment members across multiple phased pages even when a single page would fit the data, so presence of second-phase resources (Observation/Condition/Appointment) on the FIRST page is asserted warningOnly rather than hard-required; only Patient itself and its directly-referenced Organization are guaranteed on page one per the source test evidence.",
  "status": "active",
  "fixture": [
    {
      "id": "org",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Organization",
        "id": "fhir262-evx-org",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/test", "value": "EVX-ORG" }],
        "name": "Everything Test Org"
      }
    },
    {
      "id": "patient",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "fhir262-evx-pat",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/test", "value": "EVX-PAT" }],
        "name": [{ "family": "Everything", "given": ["Pat"] }],
        "managingOrganization": { "reference": "Organization/fhir262-evx-org" }
      }
    },
    {
      "id": "obs",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Observation",
        "id": "fhir262-evx-obs",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/test", "value": "EVX-OBS" }],
        "status": "final",
        "code": {
          "coding": [{ "system": "http://loinc.org", "code": "8867-4", "display": "Heart rate" }]
        },
        "subject": { "reference": "Patient/fhir262-evx-pat" },
        "valueQuantity": { "value": 88, "unit": "beats/minute", "system": "http://unitsofmeasure.org", "code": "/min" }
      }
    },
    {
      "id": "cond",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Condition",
        "id": "fhir262-evx-cond",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/test", "value": "EVX-COND" }],
        "subject": { "reference": "Patient/fhir262-evx-pat" },
        "code": {
          "coding": [{ "system": "http://snomed.info/sct", "code": "38341003", "display": "Hypertension" }]
        }
      }
    },
    {
      "id": "appt",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Appointment",
        "id": "fhir262-evx-appt",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/test", "value": "EVX-APPT" }],
        "status": "booked",
        "participant": [
          { "actor": { "reference": "Patient/fhir262-evx-pat" }, "status": "accepted" }
        ]
      }
    },
    {
      "id": "other-patient",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "fhir262-evx-other",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/test", "value": "EVX-OTHER-PAT" }],
        "name": [{ "family": "Decoy", "given": ["Other"] }]
      }
    },
    {
      "id": "other-obs",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Observation",
        "id": "fhir262-evx-other-obs",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/test", "value": "EVX-OTHER-OBS" }],
        "status": "final",
        "code": {
          "coding": [{ "system": "http://loinc.org", "code": "29463-7", "display": "Body weight" }]
        },
        "subject": { "reference": "Patient/fhir262-evx-other" },
        "valueQuantity": { "value": 60, "unit": "kg", "system": "http://unitsofmeasure.org", "code": "kg" }
      }
    }
  ],
  "setup": {
    "action": [
      { "operation": { "type": { "code": "update" }, "url": "Organization/fhir262-evx-org", "sourceId": "org", "description": "PUT Organization/fhir262-evx-org" } },
      { "operation": { "type": { "code": "update" }, "url": "Patient/fhir262-evx-pat", "sourceId": "patient", "description": "PUT Patient/fhir262-evx-pat (managingOrganization=org)" } },
      { "operation": { "type": { "code": "update" }, "url": "Observation/fhir262-evx-obs", "sourceId": "obs", "description": "PUT Observation/fhir262-evx-obs (subject=pat)" } },
      { "operation": { "type": { "code": "update" }, "url": "Condition/fhir262-evx-cond", "sourceId": "cond", "description": "PUT Condition/fhir262-evx-cond (subject=pat)" } },
      { "operation": { "type": { "code": "update" }, "url": "Appointment/fhir262-evx-appt", "sourceId": "appt", "description": "PUT Appointment/fhir262-evx-appt (participant=pat)" } },
      { "operation": { "type": { "code": "update" }, "url": "Patient/fhir262-evx-other", "sourceId": "other-patient", "description": "PUT Patient/fhir262-evx-other (decoy, unrelated patient)" } },
      { "operation": { "type": { "code": "update" }, "url": "Observation/fhir262-evx-other-obs", "sourceId": "other-obs", "description": "PUT Observation/fhir262-evx-other-obs (subject=other, decoy)" } }
    ]
  },
  "test": [
    {
      "name": "$everything: full compartment fetch",
      "description": "GET /Patient/fhir262-evx-pat/$everything must return the patient and its directly-referenced organization; compartment members (observation/condition/appointment) may be paged onto a later phase by the server so their presence on this first page is checked but not required. The decoy patient and its observation must never appear.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "$everything" }, "method": "GET", "url": "Patient/fhir262-evx-pat/$everything", "responseId": "evx-full", "description": "GET Patient/fhir262-evx-pat/$everything" } },
        { "assert": { "description": "Must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include the patient itself", "expression": "entry.where(resource.id = 'fhir262-evx-pat').exists()" } },
        { "assert": { "description": "Must include the managing organization", "expression": "entry.where(resource.id = 'fhir262-evx-org').exists()" } },
        { "assert": { "description": "Should include the observation (warningOnly: may be on a later phase/page)", "expression": "entry.where(resource.id = 'fhir262-evx-obs').exists()", "warningOnly": true } },
        { "assert": { "description": "Should include the condition (warningOnly: may be on a later phase/page)", "expression": "entry.where(resource.id = 'fhir262-evx-cond').exists()", "warningOnly": true } },
        { "assert": { "description": "Should include the appointment (warningOnly: may be on a later phase/page)", "expression": "entry.where(resource.id = 'fhir262-evx-appt').exists()", "warningOnly": true } },
        { "assert": { "description": "Must NOT include the decoy patient", "expression": "entry.where(resource.id = 'fhir262-evx-other').empty()" } },
        { "assert": { "description": "Must NOT include the decoy patient's observation", "expression": "entry.where(resource.id = 'fhir262-evx-other-obs').empty()" } }
      ]
    },
    {
      "name": "$everything: _type filter narrows compartment content",
      "description": "GET /Patient/fhir262-evx-pat/$everything?_type=Patient,Observation must return the patient and observation (both requested types) but exclude the condition, appointment, and organization (none of which are Patient or Observation).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "$everything" }, "method": "GET", "url": "Patient/fhir262-evx-pat/$everything?_type=Patient,Observation", "responseId": "evx-type-filter", "description": "GET Patient/fhir262-evx-pat/$everything?_type=Patient,Observation" } },
        { "assert": { "description": "Must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include the patient", "expression": "entry.where(resource.id = 'fhir262-evx-pat').exists()" } },
        { "assert": { "description": "Must include the observation", "expression": "entry.where(resource.id = 'fhir262-evx-obs').exists()" } },
        { "assert": { "description": "Must NOT include the condition (not in _type list)", "expression": "entry.where(resource.id = 'fhir262-evx-cond').empty()" } },
        { "assert": { "description": "Must NOT include the appointment (not in _type list)", "expression": "entry.where(resource.id = 'fhir262-evx-appt').empty()" } },
        { "assert": { "description": "Must NOT include the organization (not in _type list)", "expression": "entry.where(resource.id = 'fhir262-evx-org').empty()" } }
      ]
    },
    {
      "name": "$everything: invalid _type value returns an empty bundle",
      "description": "GET /Patient/fhir262-evx-pat/$everything?_type=foo requests a nonexistent resource type; the server must return HTTP 200 with an empty Bundle (no entries, not even the patient itself).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "$everything" }, "method": "GET", "url": "Patient/fhir262-evx-pat/$everything?_type=foo", "responseId": "evx-invalid-type", "description": "GET Patient/fhir262-evx-pat/$everything?_type=foo" } },
        { "assert": { "description": "Must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Bundle must have no entries", "expression": "entry.empty()" } }
      ]
    },
    {
      "name": "$everything: far-future _since returns an empty bundle",
      "description": "GET /Patient/fhir262-evx-pat/$everything?_since=3000 filters by a last-updated timestamp far in the future; since none of the fixtures were last modified after year 3000, the bundle must be empty.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "$everything" }, "method": "GET", "url": "Patient/fhir262-evx-pat/$everything?_since=3000", "responseId": "evx-since-future", "description": "GET Patient/fhir262-evx-pat/$everything?_since=3000" } },
        { "assert": { "description": "Must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Bundle must have no entries", "expression": "entry.empty()" } }
      ]
    },
    {
      "name": "$everything: invalid continuation token is rejected",
      "description": "GET /Patient/fhir262-evx-pat/$everything?ct=abc supplies a malformed continuation token; the server must reject the request with HTTP 400.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "$everything" }, "method": "GET", "url": "Patient/fhir262-evx-pat/$everything?ct=abc", "responseId": "evx-bad-ct", "description": "GET Patient/fhir262-evx-pat/$everything?ct=abc" } },
        { "assert": { "description": "Must return HTTP 400", "response": "bad" } }
      ]
    },
    {
      "name": "$everything: unsupported resource type returns 404",
      "description": "GET /Observation/bar/$everything invokes $everything on a resource type that does not support the operation (only Patient does); the server must return HTTP 404.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "$everything" }, "method": "GET", "url": "Observation/bar/$everything", "responseId": "evx-unsupported-type", "description": "GET Observation/bar/$everything" } },
        { "assert": { "description": "Must return HTTP 404", "response": "notFound" } }
      ]
    },
    {
      "name": "$everything: unsupported input parameters produce a warning outcome but real results still return",
      "description": "GET /Patient/fhir262-evx-pat/$everything?_count=100&foo=bar passes two parameters $everything does not accept (_count and foo). Both must be flagged in the returned OperationOutcome with severity=warning and code=not-supported, while the patient and its organization still appear in the same bundle.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "$everything" }, "method": "GET", "url": "Patient/fhir262-evx-pat/$everything?_count=100&foo=bar", "responseId": "evx-unsupported-params", "description": "GET Patient/fhir262-evx-pat/$everything?_count=100&foo=bar" } },
        { "assert": { "description": "Must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must still include the patient", "expression": "entry.where(resource.id = 'fhir262-evx-pat').exists()" } },
        { "assert": { "description": "Must still include the organization", "expression": "entry.where(resource.id = 'fhir262-evx-org').exists()" } },
        { "assert": { "description": "Must contain at least 2 warning/not-supported OperationOutcome issues (one per unsupported parameter)", "expression": "entry.resource.ofType(OperationOutcome).issue.where(severity = 'warning' and code = 'not-supported').count() >= 2" } },
        { "assert": { "description": "An issue diagnostics should mention '_count' (warningOnly: exact message wording varies)", "expression": "entry.resource.ofType(OperationOutcome).issue.diagnostics.where($this.contains('_count')).exists()", "warningOnly": true } },
        { "assert": { "description": "An issue diagnostics should mention 'foo' (warningOnly: exact message wording varies)", "expression": "entry.resource.ofType(OperationOutcome).issue.diagnostics.where($this.contains('foo')).exists()", "warningOnly": true } }
      ]
    }
  ],
  "teardown": {
    "action": [
      { "operation": { "type": { "code": "delete" }, "url": "Observation/fhir262-evx-other-obs", "description": "Teardown: delete decoy observation" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/fhir262-evx-other", "description": "Teardown: delete decoy patient" } },
      { "operation": { "type": { "code": "delete" }, "url": "Appointment/fhir262-evx-appt", "description": "Teardown: delete appointment" } },
      { "operation": { "type": { "code": "delete" }, "url": "Condition/fhir262-evx-cond", "description": "Teardown: delete condition" } },
      { "operation": { "type": { "code": "delete" }, "url": "Observation/fhir262-evx-obs", "description": "Teardown: delete observation" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/fhir262-evx-pat", "description": "Teardown: delete patient" } },
      { "operation": { "type": { "code": "delete" }, "url": "Organization/fhir262-evx-org", "description": "Teardown: delete organization" } }
    ]
  }
}
