  "test": [
    {
      "name": "$bulk-delete kick-off: system-level, multiple resource types",
      "description": "DELETE /$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-basic with Prefer: respond-async must return 202 Accepted with a non-empty Content-Location job-status header, matching GivenVariousResourcesOfDifferentTypes_WhenBulkDeleted_ThenAllAreDeleted (job completion itself is not verified; see suite description).",
      "action": [
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-basic", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-basic-kickoff", "description": "DELETE $bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-basic" } },
        { "assert": { "description": "Kick-off must return 202 Accepted", "responseCode": "202" } },
        { "assert": { "description": "Content-Location header must be present and non-empty", "headerField": "Content-Location" } }
      ]
    },
    {
      "name": "$bulk-delete: single best-effort status poll",
      "description": "GET the Content-Location captured from the basic kickoff. This is a single request, not a wait loop; the job may already be complete (200 + Parameters) or still running (202) by the time this runs, so the whole assertion is warningOnly.",
      "action": [
        { "operation": { "type": { "code": "read" }, "method": "GET", "url": "${bulkDeleteBasicLocation}", "responseId": "bulk-delete-basic-poll", "description": "GET the bulk-delete job status URL" } },
        { "assert": { "description": "Status poll should return a 2xx status, either 202 (still running) or 200 (complete) (warningOnly: timing-dependent)", "response": "okay", "warningOnly": true } }
      ]
    },
    {
      "name": "$bulk-delete: invalid search parameter is rejected with 400",
      "description": "DELETE /$bulk-delete?_tag=...&invalidParam=badRequest supplies a query parameter that is not a valid search parameter; this is fully synchronous validation (no job is created) and must return 400, matching GivenBulkDeleteRequestWithInvalidSearchParameters_WhenRequested_ThenBadRequestIsReturned.",
      "action": [
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-badreq&invalidParam=badRequest", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-bad-request", "description": "DELETE $bulk-delete?_tag=...&invalidParam=badRequest" } },
        { "assert": { "description": "Must return HTTP 400", "response": "bad" } }
      ]
    },
    {
      "name": "$bulk-delete kick-off: type-scoped (Organization/$bulk-delete)",
      "description": "DELETE /Organization/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-typeorg must return 202 Accepted with a Content-Location header, matching GivenResourcesOfOneType_WhenBulkDeletedByType_ThenAllOfThatTypeAreDeleted.",
      "action": [
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Organization/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-typeorg", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-type-scoped-kickoff", "description": "DELETE Organization/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-typeorg" } },
        { "assert": { "description": "Type-scoped kick-off must return 202 Accepted", "response": "okay" } },
        { "assert": { "description": "Content-Location header must be present and non-empty", "headerField": "Content-Location" } }
      ]
    },
    {
      "name": "$bulk-delete kick-off accepts hardDelete / purgeHistory / excludedResourceTypes / _include / _revinclude / _remove-references options",
      "description": "Each of BulkDeleteTests' documented optional query parameters must be accepted at kick-off time and return 202 Accepted: _hardDelete=true (GivenHardBulkDeleteRequest...), _purgeHistory=true (GivenPurgeBulkDeleteRequest...), excludedResourceTypes (GivenBulkDeleteRequestWithMultipleExcludedResourceTypes...), _include=Observation:* (GivenBulkDeleteJobWithIncludeSearch...), _revinclude=*:* (GivenBulkDeleteJobWithRevincludeSearch...), and _hardDelete=true&_remove-references=true together (GivenABulkDeleteJob_WhenRemovingReferences_ThenReferencesAreRemoved). Only kick-off acceptance is checked; the resulting deletion counts are not verified (no polling-until-complete primitive).",
      "action": [
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Patient/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-hard&_hardDelete=true", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-hard-kickoff", "description": "DELETE Patient/$bulk-delete?_tag=...&_hardDelete=true" } },
        { "assert": { "description": "_hardDelete=true kick-off must return 202 Accepted", "sourceId": "bulk-delete-hard-kickoff", "response": "okay" } },
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Patient/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-purge&_purgeHistory=true", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-purge-kickoff", "description": "DELETE Patient/$bulk-delete?_tag=...&_purgeHistory=true" } },
        { "assert": { "description": "_purgeHistory=true kick-off must return 202 Accepted", "sourceId": "bulk-delete-purge-kickoff", "response": "okay" } },
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-excl&excludedResourceTypes=Observation", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-excluded-kickoff", "description": "DELETE $bulk-delete?_tag=...&excludedResourceTypes=Observation" } },
        { "assert": { "description": "excludedResourceTypes kick-off must return 202 Accepted", "sourceId": "bulk-delete-excluded-kickoff", "response": "okay" } },
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Observation/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-incl&_include=Observation:*", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-include-kickoff", "description": "DELETE Observation/$bulk-delete?_tag=...&_include=Observation:*" } },
        { "assert": { "description": "_include kick-off must return 202 Accepted", "sourceId": "bulk-delete-include-kickoff", "response": "okay" } },
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Patient/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-revincl&_revinclude=*:*", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-revinclude-kickoff", "description": "DELETE Patient/$bulk-delete?_tag=...&_revinclude=*:*" } },
        { "assert": { "description": "_revinclude kick-off must return 202 Accepted", "sourceId": "bulk-delete-revinclude-kickoff", "response": "okay" } },
        { "operation": { "type": { "code": "$bulk-delete" }, "method": "DELETE", "url": "Patient/$bulk-delete?_tag=http://ignixa.io/testscript/suite/test|fhir262-bd-remref&_hardDelete=true&_remove-references=true", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-delete-remove-references-kickoff", "description": "DELETE Patient/$bulk-delete?_tag=...&_hardDelete=true&_remove-references=true" } },
        { "assert": { "description": "_remove-references kick-off must return 202 Accepted", "sourceId": "bulk-delete-remove-references-kickoff", "response": "okay" } }
      ]
    }
  ],
