{
  "resourceType": "TestScript",
  "name": "Operations/ms-bulk-update",
  "description": "$bulk-update conformance tests: FHIRPath-Patch async job kick-off (202 + Content-Location) at system and type scope, _isParallel option, and validation-failure scenarios (invalid search parameter, unsupported patch-type combination, unsupported resource types) (from BulkUpdateTests). Job completion is not verified, only kick-off acceptance and a single best-effort status poll (warningOnly).",
  "status": "active",
  "fixture": [
    {
      "id": "patch-replace-gender",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Parameters",
        "parameter": [
          {
            "name": "operation",
            "part": [
              { "name": "type", "valueString": "replace" },
              { "name": "path", "valueString": "Patient.gender" },
              { "name": "value", "valueCode": "female" }
            ]
          }
        ]
      }
    },
    {
      "id": "patch-unsupported-combo",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Parameters",
        "parameter": [
          {
            "name": "operation",
            "part": [
              { "name": "type", "valueString": "add" },
              { "name": "path", "valueString": "Patient" },
              { "name": "name", "valueString": "gender" },
              { "name": "value", "valueCode": "female" }
            ]
          },
          {
            "name": "operation",
            "part": [
              { "name": "type", "valueString": "insert" },
              { "name": "path", "valueString": "Patient.nothing" },
              { "name": "value", "valueString": "test" },
              { "name": "index", "valueInteger": 2 }
            ]
          }
        ]
      }
    },
    {
      "id": "patch-empty",
      "autocreate": false,
      "autodelete": false,
      "resource": { "resourceType": "Parameters", "parameter": [] }
    },
    {
      "id": "patch-replace-active",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Parameters",
        "parameter": [
          {
            "name": "operation",
            "part": [
              { "name": "type", "valueString": "replace" },
              { "name": "path", "valueString": "Patient.active" },
              { "name": "value", "valueBoolean": true }
            ]
          }
        ]
      }
    },
    {
      "id": "sys-pat1",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "ignixa-bu-sys-pat1",
        "meta": { "tag": [{ "system": "http://ignixa.io/testscript/suite/test", "code": "ignixa-bu-sys" }] },
        "name": [{ "family": "BulkUpdateSystem", "given": ["Pat"] }]
      }
    },
    {
      "id": "type-pat1",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "ignixa-bu-type-pat1",
        "meta": { "tag": [{ "system": "http://ignixa.io/testscript/suite/test", "code": "ignixa-bu-type" }] },
        "name": [{ "family": "BulkUpdateTypeScoped", "given": ["Pat"] }]
      }
    }
  ],
  "variable": [
    {
      "name": "bulkUpdateLocation",
      "sourceId": "bulk-update-system-kickoff",
      "headerField": "Content-Location",
      "defaultValue": "$bulk-update",
      "description": "Job-status URL from the kickoff response's Content-Location header (falls back to $bulk-update if absent)."
    }
  ],
  "setup": {
    "action": [
      { "operation": { "type": { "code": "update" }, "url": "Patient/ignixa-bu-sys-pat1", "sourceId": "sys-pat1", "description": "PUT Patient/ignixa-bu-sys-pat1 (tag=ignixa-bu-sys)" } },
      { "operation": { "type": { "code": "update" }, "url": "Patient/ignixa-bu-type-pat1", "sourceId": "type-pat1", "description": "PUT Patient/ignixa-bu-type-pat1 (tag=ignixa-bu-type)" } }
    ]
  },
  "test": [
    {
      "name": "$bulk-update: invalid search parameter is rejected with 400",
      "description": "An invalid search parameter must be rejected with 400 even with a valid patch body, before any job is created.",
      "action": [
        { "operation": { "type": { "code": "$bulk-update" }, "method": "PATCH", "url": "$bulk-update?_tag=http://ignixa.io/testscript/suite/test|ignixa-bu-badreq&invalidParam=badRequest", "sourceId": "patch-replace-gender", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-update-bad-search-param", "description": "PATCH $bulk-update?_tag=...&invalidParam=badRequest" } },
        { "assert": { "description": "Must return HTTP 400", "response": "bad" } }
      ]
    },
    {
      "name": "$bulk-update: unsupported patch type combination is rejected with 400",
      "description": "An 'add' on a single-cardinality element (Patient.gender) combined with an 'insert' on a nonexistent list path must be rejected with 400.",
      "action": [
        { "operation": { "type": { "code": "$bulk-update" }, "method": "PATCH", "url": "$bulk-update?_tag=http://ignixa.io/testscript/suite/test|ignixa-bu-unsupported", "sourceId": "patch-unsupported-combo", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-update-unsupported-type", "description": "PATCH $bulk-update?_tag=... with add(Patient.gender)+insert(Patient.nothing)" } },
        { "assert": { "description": "Must return HTTP 400", "response": "bad" } }
      ]
    },
    {
      "name": "$bulk-update: unsupported resource types (SearchParameter, StructureDefinition) are rejected with 400",
      "description": "$bulk-update on excluded resource types (SearchParameter, StructureDefinition) must be rejected with 400 even with an empty patch body.",
      "action": [
        { "operation": { "type": { "code": "$bulk-update" }, "method": "PATCH", "url": "SearchParameter/$bulk-update?_tag=http://ignixa.io/testscript/suite/test|ignixa-bu-restype", "sourceId": "patch-empty", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-update-searchparameter-response", "description": "PATCH SearchParameter/$bulk-update?_tag=... with an empty Parameters body" } },
        { "assert": { "description": "SearchParameter/$bulk-update must return HTTP 400", "sourceId": "bulk-update-searchparameter-response", "response": "bad" } },
        { "operation": { "type": { "code": "$bulk-update" }, "method": "PATCH", "url": "StructureDefinition/$bulk-update?_tag=http://ignixa.io/testscript/suite/test|ignixa-bu-restype", "sourceId": "patch-empty", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-update-structuredefinition-response", "description": "PATCH StructureDefinition/$bulk-update?_tag=... with an empty Parameters body" } },
        { "assert": { "description": "StructureDefinition/$bulk-update must return HTTP 400", "sourceId": "bulk-update-structuredefinition-response", "response": "bad" } }
      ]
    },
    {
      "name": "$bulk-update kick-off: system-level with a valid patch returns 202 Accepted",
      "description": "A valid patch submitted system-level must return 202 Accepted with a non-empty Content-Location header.",
      "action": [
        { "operation": { "type": { "code": "$bulk-update" }, "method": "PATCH", "url": "$bulk-update?_tag=http://ignixa.io/testscript/suite/test|ignixa-bu-sys", "sourceId": "patch-replace-active", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-update-system-kickoff", "description": "PATCH $bulk-update?_tag=http://ignixa.io/testscript/suite/test|ignixa-bu-sys" } },
        { "assert": { "description": "Kick-off must return 202 Accepted", "responseCode": "202" } },
        { "assert": { "description": "Content-Location header must be present and non-empty", "headerField": "Content-Location" } }
      ]
    },
    {
      "name": "$bulk-update: single best-effort status poll",
      "description": "A single status check on the kicked-off job's Content-Location; warningOnly since the job may finish before or after this check.",
      "action": [
        { "operation": { "type": { "code": "read" }, "method": "GET", "url": "${bulkUpdateLocation}", "responseId": "bulk-update-status-poll", "description": "GET the bulk-update job status URL" } },
        { "assert": { "description": "Status poll should return a 2xx status, either 202 (still running) or 200 (complete) (warningOnly: timing-dependent)", "response": "okay", "warningOnly": true } }
      ]
    },
    {
      "name": "$bulk-update kick-off: type-scoped (Patient/$bulk-update) accepts both _isParallel=true and _isParallel=false",
      "description": "A valid patch submitted type-scoped (Patient) must return 202 Accepted with both _isParallel=true and _isParallel=false.",
      "action": [
        { "operation": { "type": { "code": "$bulk-update" }, "method": "PATCH", "url": "Patient/$bulk-update?_tag=http://ignixa.io/testscript/suite/test|ignixa-bu-type&_isParallel=true", "sourceId": "patch-replace-active", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-update-type-parallel-true-kickoff", "description": "PATCH Patient/$bulk-update?_tag=...&_isParallel=true" } },
        { "assert": { "description": "_isParallel=true kick-off must return 202 Accepted", "sourceId": "bulk-update-type-parallel-true-kickoff", "response": "okay" } },
        { "operation": { "type": { "code": "$bulk-update" }, "method": "PATCH", "url": "Patient/$bulk-update?_tag=http://ignixa.io/testscript/suite/test|ignixa-bu-type&_isParallel=false", "sourceId": "patch-replace-active", "requestHeader": [ { "field": "Prefer", "value": "respond-async" } ], "responseId": "bulk-update-type-parallel-false-kickoff", "description": "PATCH Patient/$bulk-update?_tag=...&_isParallel=false" } },
        { "assert": { "description": "_isParallel=false kick-off must return 202 Accepted", "sourceId": "bulk-update-type-parallel-false-kickoff", "response": "okay" } }
      ]
    }
  ],
  "teardown": {
    "action": [
      { "operation": { "type": { "code": "delete" }, "url": "Patient/ignixa-bu-sys-pat1", "description": "Teardown: delete sys-pat1" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/ignixa-bu-type-pat1", "description": "Teardown: delete type-pat1" } }
    ]
  }
}
