{
  "resourceType": "TestScript",
  "name": "CRUD/conditional-update",
  "description": "Conditional update (PUT /Patient?search-params) conformance tests: upsert-on-no-match, 400 on no criteria, body-id agreement/mismatch handling, and 412 on multiple matches.",
  "status": "active",
  "fixture": [
    {
      "id": "patient-nomatch-body",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "name": [{ "family": "CondUpdate", "given": ["NoMatch"] }],
        "gender": "unknown"
      }
    },
    {
      "id": "patient-explicit-id-body",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "fhir262-cond-upd-explicit",
        "name": [{ "family": "CondUpdate", "given": ["Explicit"] }],
        "gender": "male"
      }
    },
    {
      "id": "patient-seed-onematch-body",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/cond-update", "value": "CU-ONEMATCH" }],
        "name": [{ "family": "CondUpdate", "given": ["OneMatch"] }],
        "gender": "male"
      }
    },
    {
      "id": "patient-update-onematch-body",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "name": [{ "family": "CondUpdate", "given": ["OneMatchUpdated"] }],
        "gender": "female"
      }
    },
    {
      "id": "patient-seed-correctid-body",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "fhir262-cond-upd-correctid",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/cond-update", "value": "CU-CORRECTID" }],
        "name": [{ "family": "CondUpdate", "given": ["CorrectId"] }],
        "gender": "male"
      }
    },
    {
      "id": "patient-update-correctid-body",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "fhir262-cond-upd-correctid",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/cond-update", "value": "CU-CORRECTID" }],
        "name": [{ "family": "CondUpdate", "given": ["CorrectId"] }],
        "gender": "female"
      }
    },
    {
      "id": "patient-update-wrongid-body",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "fhir262-cond-upd-wrongid",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/cond-update", "value": "CU-CORRECTID" }],
        "name": [{ "family": "CondUpdate", "given": ["WrongId"] }],
        "gender": "female"
      }
    },
    {
      "id": "patient-seed-multi-a-body",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/cond-update", "value": "CU-MULTI" }],
        "name": [{ "family": "CondUpdate", "given": ["MultiA"] }]
      }
    },
    {
      "id": "patient-seed-multi-b-body",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/cond-update", "value": "CU-MULTI" }],
        "name": [{ "family": "CondUpdate", "given": ["MultiB"] }]
      }
    },
    {
      "id": "patient-update-multi-body",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "name": [{ "family": "CondUpdate", "given": ["MultiUpdated"] }]
      }
    }
  ],
  "variable": [
    {
      "name": "seedOneMatchId",
      "sourceId": "seed-onematch-response",
      "path": "id",
      "description": "Server-assigned id of the Patient unconditionally created in setup that carries identifier CU-ONEMATCH"
    }
  ],
  "setup": {
    "action": [
      { "operation": { "type": { "code": "create" }, "resource": "Patient", "sourceId": "patient-seed-onematch-body", "responseId": "seed-onematch-response", "description": "Unconditionally create the Patient that later conditional-update attempts should match exactly once (CU-ONEMATCH)" } },
      { "operation": { "type": { "code": "update" }, "url": "Patient/fhir262-cond-upd-correctid", "sourceId": "patient-seed-correctid-body", "responseId": "seed-correctid-response", "description": "PUT a client-id Patient (CU-CORRECTID) so later tests can deterministically match or mismatch its id in a conditional update body" } },
      { "operation": { "type": { "code": "create" }, "resource": "Patient", "sourceId": "patient-seed-multi-a-body", "responseId": "seed-multi-a-response", "description": "Unconditionally create the first of two Patients sharing identifier CU-MULTI" } },
      { "operation": { "type": { "code": "create" }, "resource": "Patient", "sourceId": "patient-seed-multi-b-body", "responseId": "seed-multi-b-response", "description": "Unconditionally create the second of two Patients sharing identifier CU-MULTI" } }
    ]
  },
  "test": [
    {
      "name": "Conditional update with no existing match upserts a new resource",
      "description": "PUT /Patient?identifier=... matching no existing resource with an id-less body; the server must upsert (create) it and return 201 Created.",
      "action": [
        { "operation": { "type": { "code": "update" }, "resource": "Patient", "params": "?identifier=http://ignixa.io/testscript/suite/cond-update|CU-NOMATCH", "sourceId": "patient-nomatch-body", "responseId": "cu-nomatch-response", "description": "Conditional PUT /Patient?identifier=...CU-NOMATCH, matches nothing" } },
        { "assert": { "description": "Must return HTTP 201 Created", "response": "created" } },
        { "assert": { "description": "Response body must be a Patient", "resource": "Patient" } },
        { "assert": { "description": "Server must have assigned an id", "expression": "Patient.id.exists()" } }
      ]
    },
    {
      "name": "Conditional update with no search criteria is rejected",
      "description": "PUT /Patient with no search criteria; the server must reject the request with 400 Bad Request.",
      "action": [
        { "operation": { "type": { "code": "update" }, "resource": "Patient", "sourceId": "patient-nomatch-body", "responseId": "cu-nocriteria-response", "description": "Conditional PUT /Patient with no query string" } },
        { "assert": { "description": "Must return HTTP 400 Bad Request", "response": "bad" } }
      ]
    },
    {
      "name": "Conditional update with a client-supplied id and no existing match creates that id",
      "description": "PUT /Patient?identifier=... matching no existing resource with a body carrying a client-supplied id; the server must create the resource using that id and return 201 Created.",
      "action": [
        { "operation": { "type": { "code": "update" }, "resource": "Patient", "params": "?identifier=http://ignixa.io/testscript/suite/cond-update|CU-EXPLICIT", "sourceId": "patient-explicit-id-body", "responseId": "cu-explicit-response", "description": "Conditional PUT /Patient?identifier=...CU-EXPLICIT, body carries id=fhir262-cond-upd-explicit" } },
        { "assert": { "description": "Must return HTTP 201 Created", "response": "created" } },
        { "assert": { "description": "Server must have used the client-supplied id", "expression": "Patient.id", "value": "fhir262-cond-upd-explicit", "operator": "equals" } }
      ]
    },
    {
      "name": "Conditional update with no id in body and one match updates the existing resource",
      "description": "PUT /Patient?identifier=... matching exactly one existing Patient with an id-less body; the server must update it in place and return 200 OK with the same id.",
      "action": [
        { "operation": { "type": { "code": "update" }, "resource": "Patient", "params": "?identifier=http://ignixa.io/testscript/suite/cond-update|CU-ONEMATCH", "sourceId": "patient-update-onematch-body", "responseId": "cu-onematch-response", "description": "Conditional PUT /Patient?identifier=...CU-ONEMATCH, matches the single seeded Patient" } },
        { "assert": { "description": "Must return HTTP 200 OK (updated, not created)", "response": "okay" } },
        { "assert": { "description": "Returned id must match the existing seeded resource's id", "expression": "Patient.id", "value": "${seedOneMatchId}", "operator": "equals" } }
      ]
    },
    {
      "name": "Conditional update with a body id matching the resolved resource updates its content",
      "description": "PUT /Patient?identifier=... matching one existing Patient whose id agrees with the body's id; the server must accept the update and return 200 OK with the updated content.",
      "action": [
        { "operation": { "type": { "code": "update" }, "resource": "Patient", "params": "?identifier=http://ignixa.io/testscript/suite/cond-update|CU-CORRECTID", "sourceId": "patient-update-correctid-body", "responseId": "cu-correctid-response", "description": "Conditional PUT /Patient?identifier=...CU-CORRECTID, body id matches the resolved resource's id" } },
        { "assert": { "description": "Must return HTTP 200 OK", "response": "okay" } },
        { "assert": { "description": "Id must remain fhir262-cond-upd-correctid", "expression": "Patient.id", "value": "fhir262-cond-upd-correctid", "operator": "equals" } },
        { "assert": { "description": "Content must reflect the update (gender changed to female)", "expression": "Patient.gender", "value": "female", "operator": "equals" } }
      ]
    },
    {
      "name": "Conditional update with a mismatched body id is rejected",
      "description": "PUT /Patient?identifier=... matching one existing Patient whose id disagrees with the body's id; the server must reject the request with 400 Bad Request.",
      "action": [
        { "operation": { "type": { "code": "update" }, "resource": "Patient", "params": "?identifier=http://ignixa.io/testscript/suite/cond-update|CU-CORRECTID", "sourceId": "patient-update-wrongid-body", "responseId": "cu-mismatch-response", "description": "Conditional PUT /Patient?identifier=...CU-CORRECTID, body id deliberately disagrees with the resolved resource's id" } },
        { "assert": { "description": "Must return HTTP 400 Bad Request", "response": "bad" } }
      ]
    },
    {
      "name": "Conditional update with multiple existing matches fails",
      "description": "PUT /Patient?identifier=... matching two existing Patients; the server must return 412 Precondition Failed since the criteria isn't selective enough.",
      "action": [
        { "operation": { "type": { "code": "update" }, "resource": "Patient", "params": "?identifier=http://ignixa.io/testscript/suite/cond-update|CU-MULTI", "sourceId": "patient-update-multi-body", "responseId": "cu-multi-response", "description": "Conditional PUT /Patient?identifier=...CU-MULTI, matches both seeded Patients" } },
        { "assert": { "description": "Must return HTTP 412 Precondition Failed", "response": "preconditionFailed" } }
      ]
    }
  ],
  "teardown": {
    "action": [
      { "operation": { "type": { "code": "delete" }, "resource": "Patient", "params": "?identifier=http://ignixa.io/testscript/suite/cond-update|CU-NOMATCH", "description": "Teardown: conditional delete the CU-NOMATCH Patient" } },
      { "operation": { "type": { "code": "delete" }, "resource": "Patient", "params": "?identifier=http://ignixa.io/testscript/suite/cond-update|CU-EXPLICIT", "description": "Teardown: conditional delete the CU-EXPLICIT Patient" } },
      { "operation": { "type": { "code": "delete" }, "resource": "Patient", "params": "?identifier=http://ignixa.io/testscript/suite/cond-update|CU-ONEMATCH", "description": "Teardown: conditional delete the CU-ONEMATCH Patient" } },
      { "operation": { "type": { "code": "delete" }, "resource": "Patient", "params": "?identifier=http://ignixa.io/testscript/suite/cond-update|CU-CORRECTID", "description": "Teardown: conditional delete the CU-CORRECTID Patient" } },
      { "operation": { "type": { "code": "delete" }, "resource": "Patient", "params": "?identifier=http://ignixa.io/testscript/suite/cond-update|CU-MULTI", "description": "Teardown: conditional delete both CU-MULTI Patients" } }
    ]
  }
}
