{
  "resourceType": "TestScript",
  "name": "CRUD/all-resource-types-pre-r5",
  "description": "Creates and reads every concrete FHIR resource type present in STU3 through R4B but removed in R5, gated on the target declaring fhirVersion 3.0.x, 4.0.x, or 4.3.x.",
  "status": "active",
  "fixture": [
    {
      "id": "deviceUseStatement-fixture",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "extension": [
          {
            "url": "http://ignixa.io/testscript/fhirfakes",
            "valueCode": "DeviceUseStatement"
          }
        ]
      }
    },
    {
      "id": "documentManifest-fixture",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "extension": [
          {
            "url": "http://ignixa.io/testscript/fhirfakes",
            "valueCode": "DocumentManifest"
          }
        ]
      }
    },
    {
      "id": "media-fixture",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "extension": [
          {
            "url": "http://ignixa.io/testscript/fhirfakes",
            "valueCode": "Media"
          }
        ]
      }
    },
    {
      "id": "requestGroup-fixture",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "extension": [
          {
            "url": "http://ignixa.io/testscript/fhirfakes",
            "valueCode": "RequestGroup"
          }
        ]
      }
    }
  ],
  "variable": [
    {
      "name": "deviceUseStatementId",
      "sourceId": "deviceUseStatement-create-response",
      "path": "id",
      "description": "The server-assigned id for the created DeviceUseStatement"
    },
    {
      "name": "documentManifestId",
      "sourceId": "documentManifest-create-response",
      "path": "id",
      "description": "The server-assigned id for the created DocumentManifest"
    },
    {
      "name": "mediaId",
      "sourceId": "media-create-response",
      "path": "id",
      "description": "The server-assigned id for the created Media"
    },
    {
      "name": "requestGroupId",
      "sourceId": "requestGroup-create-response",
      "path": "id",
      "description": "The server-assigned id for the created RequestGroup"
    }
  ],
  "setup": {
    "action": []
  },
  "test": [
    {
      "name": "Can create and read DeviceUseStatement",
      "description": "When the target server declares DeviceUseStatement create and read interactions, POST /DeviceUseStatement must create a synthetic DeviceUseStatement and GET /DeviceUseStatement/{id} must read it back.",
      "extension": [
        {
          "url": "http://ignixa.io/testscript/fhirVersions",
          "valueString": "3.0,4.0,4.3"
        }
      ],
      "requiresCapability": "rest.resource.where(type='DeviceUseStatement').interaction.where(code='create').exists() and rest.resource.where(type='DeviceUseStatement').interaction.where(code='read').exists()",
      "action": [
        {
          "operation": {
            "type": {
              "code": "create"
            },
            "resource": "DeviceUseStatement",
            "sourceId": "deviceUseStatement-fixture",
            "responseId": "deviceUseStatement-create-response",
            "description": "POST a synthetic DeviceUseStatement"
          }
        },
        {
          "assert": {
            "description": "DeviceUseStatement create must return HTTP 201 Created",
            "sourceId": "deviceUseStatement-create-response",
            "response": "created"
          }
        },
        {
          "assert": {
            "description": "Create response body must be a DeviceUseStatement",
            "sourceId": "deviceUseStatement-create-response",
            "resource": "DeviceUseStatement"
          }
        },
        {
          "assert": {
            "description": "Server must assign an id",
            "sourceId": "deviceUseStatement-create-response",
            "expression": "DeviceUseStatement.id.exists()"
          }
        },
        {
          "operation": {
            "type": {
              "code": "read"
            },
            "url": "DeviceUseStatement/${deviceUseStatementId}",
            "responseId": "deviceUseStatement-read-response",
            "description": "GET the created DeviceUseStatement by server-assigned id"
          }
        },
        {
          "assert": {
            "description": "DeviceUseStatement read must return HTTP 200 OK",
            "sourceId": "deviceUseStatement-read-response",
            "response": "okay"
          }
        },
        {
          "assert": {
            "description": "Read response body must be a DeviceUseStatement",
            "sourceId": "deviceUseStatement-read-response",
            "resource": "DeviceUseStatement"
          }
        },
        {
          "assert": {
            "description": "Read id must match the created id",
            "sourceId": "deviceUseStatement-read-response",
            "expression": "DeviceUseStatement.id",
            "value": "${deviceUseStatementId}",
            "operator": "equals"
          }
        }
      ]
    },
