  "test": [
    {
      "name": "Can create and read EffectEvidenceSynthesis",
      "description": "When the target server declares EffectEvidenceSynthesis create and read interactions, POST /EffectEvidenceSynthesis must create a synthetic EffectEvidenceSynthesis and GET /EffectEvidenceSynthesis/{id} must read it back.",
      "extension": [
        {
          "url": "http://ignixa.io/testscript/fhirVersions",
          "valueString": "4.0"
        },
        {
          "url": "http://ignixa.io/testscript/requiresCapability",
          "valueString": "rest.resource.where(type='EffectEvidenceSynthesis').interaction.where(code='create').exists() and rest.resource.where(type='EffectEvidenceSynthesis').interaction.where(code='read').exists()"
        }
      ],
      "action": [
        {
          "operation": {
            "type": {
              "code": "create"
            },
            "resource": "EffectEvidenceSynthesis",
            "sourceId": "effectEvidenceSynthesis-fixture",
            "responseId": "effectEvidenceSynthesis-create-response",
            "description": "POST a synthetic EffectEvidenceSynthesis"
          }
        },
        {
          "assert": {
            "description": "EffectEvidenceSynthesis create must return HTTP 201 Created",
            "sourceId": "effectEvidenceSynthesis-create-response",
            "response": "created"
          }
        },
        {
          "assert": {
            "description": "Create response body must be a EffectEvidenceSynthesis",
            "sourceId": "effectEvidenceSynthesis-create-response",
            "resource": "EffectEvidenceSynthesis"
          }
        },
        {
          "assert": {
            "description": "Server must assign an id",
            "sourceId": "effectEvidenceSynthesis-create-response",
            "expression": "EffectEvidenceSynthesis.id.exists()"
          }
        },
        {
          "operation": {
            "type": {
              "code": "read"
            },
            "url": "EffectEvidenceSynthesis/${effectEvidenceSynthesisId}",
            "responseId": "effectEvidenceSynthesis-read-response",
            "description": "GET the created EffectEvidenceSynthesis by server-assigned id"
          }
        },
        {
          "assert": {
            "description": "EffectEvidenceSynthesis read must return HTTP 200 OK",
            "sourceId": "effectEvidenceSynthesis-read-response",
            "response": "okay"
          }
        },
        {
          "assert": {
            "description": "Read response body must be a EffectEvidenceSynthesis",
            "sourceId": "effectEvidenceSynthesis-read-response",
            "resource": "EffectEvidenceSynthesis"
          }
        },
        {
          "assert": {
            "description": "Read id must match the created id",
            "sourceId": "effectEvidenceSynthesis-read-response",
            "expression": "EffectEvidenceSynthesis.id",
            "value": "${effectEvidenceSynthesisId}",
            "operator": "equals"
          }
        }
      ]
    },
