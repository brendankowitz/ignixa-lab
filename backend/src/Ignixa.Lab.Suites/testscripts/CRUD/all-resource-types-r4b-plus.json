  "test": [
    {
      "name": "Can create and read AdministrableProductDefinition",
      "description": "When the target server declares AdministrableProductDefinition create and read interactions, POST /AdministrableProductDefinition must create a synthetic AdministrableProductDefinition and GET /AdministrableProductDefinition/{id} must read it back.",
      "extension": [
        {
          "url": "http://ignixa.io/testscript/fhirVersions",
          "valueString": "4.3,5.0"
        }
      ],
      "requiresCapability": "rest.resource.where(type='AdministrableProductDefinition').interaction.where(code='create').exists() and rest.resource.where(type='AdministrableProductDefinition').interaction.where(code='read').exists()",
      "action": [
        {
          "operation": {
            "type": {
              "code": "create"
            },
            "resource": "AdministrableProductDefinition",
            "sourceId": "administrableProductDefinition-fixture",
            "responseId": "administrableProductDefinition-create-response",
            "description": "POST a synthetic AdministrableProductDefinition"
          }
        },
        {
          "assert": {
            "description": "AdministrableProductDefinition create must return HTTP 201 Created",
            "sourceId": "administrableProductDefinition-create-response",
            "response": "created"
          }
        },
        {
          "assert": {
            "description": "Create response body must be a AdministrableProductDefinition",
            "sourceId": "administrableProductDefinition-create-response",
            "resource": "AdministrableProductDefinition"
          }
        },
        {
          "assert": {
            "description": "Server must assign an id",
            "sourceId": "administrableProductDefinition-create-response",
            "expression": "AdministrableProductDefinition.id.exists()"
          }
        },
        {
          "operation": {
            "type": {
              "code": "read"
            },
            "url": "AdministrableProductDefinition/${administrableProductDefinitionId}",
            "responseId": "administrableProductDefinition-read-response",
            "description": "GET the created AdministrableProductDefinition by server-assigned id"
          }
        },
        {
          "assert": {
            "description": "AdministrableProductDefinition read must return HTTP 200 OK",
            "sourceId": "administrableProductDefinition-read-response",
            "response": "okay"
          }
        },
        {
          "assert": {
            "description": "Read response body must be a AdministrableProductDefinition",
            "sourceId": "administrableProductDefinition-read-response",
            "resource": "AdministrableProductDefinition"
          }
        },
        {
          "assert": {
            "description": "Read id must match the created id",
            "sourceId": "administrableProductDefinition-read-response",
            "expression": "AdministrableProductDefinition.id",
            "value": "${administrableProductDefinitionId}",
            "operator": "equals"
          }
        }
      ]
    },
