    "action": []
  },
  "test": [
    {
      "name": "Can create and read SubstanceNucleicAcid",
      "description": "When the target server declares SubstanceNucleicAcid create and read interactions, POST /SubstanceNucleicAcid must create a synthetic SubstanceNucleicAcid and GET /SubstanceNucleicAcid/{id} must read it back.",
      "extension": [
        {
          "url": "http://ignixa.io/testscript/fhirVersions",
          "valueString": "4.0,5.0"
        }
      ],
      "requiresCapability": "rest.resource.where(type='SubstanceNucleicAcid').interaction.where(code='create').exists() and rest.resource.where(type='SubstanceNucleicAcid').interaction.where(code='read').exists()",
      "action": [
        {
          "operation": {
            "type": {
              "code": "create"
            },
            "resource": "SubstanceNucleicAcid",
            "sourceId": "substanceNucleicAcid-fixture",
            "responseId": "substanceNucleicAcid-create-response",
            "description": "POST a synthetic SubstanceNucleicAcid"
          }
        },
        {
          "assert": {
            "description": "SubstanceNucleicAcid create must return HTTP 201 Created",
            "sourceId": "substanceNucleicAcid-create-response",
            "response": "created"
          }
        },
        {
          "assert": {
            "description": "Create response body must be a SubstanceNucleicAcid",
            "sourceId": "substanceNucleicAcid-create-response",
            "resource": "SubstanceNucleicAcid"
          }
        },
        {
          "assert": {
            "description": "Server must assign an id",
            "sourceId": "substanceNucleicAcid-create-response",
            "expression": "SubstanceNucleicAcid.id.exists()"
          }
        },
        {
          "operation": {
            "type": {
              "code": "read"
            },
            "url": "SubstanceNucleicAcid/${substanceNucleicAcidId}",
            "responseId": "substanceNucleicAcid-read-response",
            "description": "GET the created SubstanceNucleicAcid by server-assigned id"
          }
        },
        {
          "assert": {
            "description": "SubstanceNucleicAcid read must return HTTP 200 OK",
            "sourceId": "substanceNucleicAcid-read-response",
            "response": "okay"
          }
        },
        {
          "assert": {
            "description": "Read response body must be a SubstanceNucleicAcid",
            "sourceId": "substanceNucleicAcid-read-response",
            "resource": "SubstanceNucleicAcid"
          }
        },
        {
          "assert": {
            "description": "Read id must match the created id",
            "sourceId": "substanceNucleicAcid-read-response",
            "expression": "SubstanceNucleicAcid.id",
            "value": "${substanceNucleicAcidId}",
            "operator": "equals"
          }
        }
      ]
    },
