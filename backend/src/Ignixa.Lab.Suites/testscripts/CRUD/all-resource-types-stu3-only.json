  "test": [
    {
      "name": "Can create and read BodySite",
      "description": "When the target server declares BodySite create and read interactions, POST /BodySite must create a synthetic BodySite and GET /BodySite/{id} must read it back.",
      "extension": [
        {
          "url": "http://ignixa.io/testscript/fhirVersions",
          "valueString": "3.0"
        },
        {
          "url": "http://ignixa.io/testscript/requiresCapability",
          "valueString": "rest.resource.where(type='BodySite').interaction.where(code='create').exists() and rest.resource.where(type='BodySite').interaction.where(code='read').exists()"
        }
      ],
      "action": [
        {
          "operation": {
            "type": {
              "code": "create"
            },
            "resource": "BodySite",
            "sourceId": "bodySite-fixture",
            "responseId": "bodySite-create-response",
            "description": "POST a synthetic BodySite"
          }
        },
        {
          "assert": {
            "description": "BodySite create must return HTTP 201 Created",
            "sourceId": "bodySite-create-response",
            "response": "created"
          }
        },
        {
          "assert": {
            "description": "Create response body must be a BodySite",
            "sourceId": "bodySite-create-response",
            "resource": "BodySite"
          }
        },
        {
          "assert": {
            "description": "Server must assign an id",
            "sourceId": "bodySite-create-response",
            "expression": "BodySite.id.exists()"
          }
        },
        {
          "operation": {
            "type": {
              "code": "read"
            },
            "url": "BodySite/${bodySiteId}",
            "responseId": "bodySite-read-response",
            "description": "GET the created BodySite by server-assigned id"
          }
        },
        {
          "assert": {
            "description": "BodySite read must return HTTP 200 OK",
            "sourceId": "bodySite-read-response",
            "response": "okay"
          }
        },
        {
          "assert": {
            "description": "Read response body must be a BodySite",
            "sourceId": "bodySite-read-response",
            "resource": "BodySite"
          }
        },
        {
          "assert": {
            "description": "Read id must match the created id",
            "sourceId": "bodySite-read-response",
            "expression": "BodySite.id",
            "value": "${bodySiteId}",
            "operator": "equals"
          }
        }
      ]
    },
