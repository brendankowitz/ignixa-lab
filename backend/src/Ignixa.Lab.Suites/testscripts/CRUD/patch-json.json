      "name": "edit that would leave two choice-type values present is rejected",
      "description": "Adding deceasedDateTime while deceasedBoolean already exists (without first removing it) would leave the resource with two conflicting representations of the same choice element, and must be rejected with 400.",
      "action": [
        {
          "operation": {
            "type": {
              "code": "create"
            },
            "resource": "Patient",
            "sourceId": "patient-full",
