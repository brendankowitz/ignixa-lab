  "test": [
    {
      "name": "replace and remove edits patch correctly",
      "description": "FHIRPath Patch equivalent of a JSON Patch replace-gender + remove-address edit (from JsonPatchTests); must return 200 with both edits applied.",
      "action": [
        {
          "operation": {
            "type": {
              "code": "create"
            },
            "resource": "Patient",
            "sourceId": "patient-full",
            "responseId": "create1",
            "description": "Create a fresh Patient from fixture 'patient-full' to patch in this test"
          }
        },
        {
          "assert": {
            "description": "Setup create must have returned HTTP 201",
            "response": "created",
            "sourceId": "create1"
          }
        },
        {
          "operation": {
            "type": {
              "code": "patch"
            },
            "url": "Patient/${patientId1}",
            "contentType": "application/fhir+json",
            "sourceId": "patch-replace-gender-remove-address",
            "responseId": "patch1",
            "description": "Submit the FHIRPath Patch Parameters body approximating the original JSON Patch document"
          }
        },
        {
          "assert": {
            "description": "Patch must return HTTP 200 OK",
            "response": "okay"
          }
        },
        {
          "assert": {
            "description": "gender must now be 'female'",
            "expression": "Patient.gender",
            "value": "female",
            "operator": "equals"
          }
        },
        {
          "assert": {
            "description": "address must have been removed",
            "expression": "Patient.address.exists()",
            "value": "false",
            "operator": "equals"
          }
        }
      ]
    },
    {
      "name": "malformed patch document is rejected with 400",
      "description": "FHIRPath Patch equivalent of JsonPatchTests' malformed-patch-document cases, using an unrecognized operation type; must return 400 Bad Request.",
