            "contentType": "application/fhir+json",
            "sourceId": "patch-malformed-optype",
            "responseId": "patch2",
            "description": "Submit the FHIRPath Patch Parameters body approximating the original JSON Patch document"
          }
        },
        {
          "assert": {
            "description": "Server must return 400 Bad Request for a malformed/unrecognized patch operation",
            "response": "bad"
          }
        }
      ]
    },
