        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must NOT include mid-a (system1/unit1 mismatch)", "expression": "entry.where(resource.id = 'ignixa-qty-mid-a').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include mid-b (system2/unit2 mismatch)", "expression": "entry.where(resource.id = 'ignixa-qty-mid-b').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
