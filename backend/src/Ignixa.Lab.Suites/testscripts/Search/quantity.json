      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Observation",
        "id": "ignixa-qty-sci",
        "status": "final",
        "code": { "coding": [{ "system": "http://ignixa.io/testscript/suite/test", "code": "ignixa-qty-test" }] },
        "meta": { "tag": [{ "system": "http://ignixa.io/testscript/suite/test", "code": "ignixa-qty-suite" }] },
