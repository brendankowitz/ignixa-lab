{
  "resourceType": "TestScript",
  "name": "Search/not-expression",
  "description": "The :not modifier on boolean and reference-scoped token fields, ported from Microsoft.Health.Fhir.Shared.Tests.E2E NotExpressionTests.GivenANotExpressionPattern_WhenSearched_ThenCompareResponseWithExpectedResults. The source test loads a large synthetic PractitionerRole/HealthcareService bundle and, for each PractitionerRole, asserts active:not=false matches (since active=true), active:not=true does not match, and active:not=false combined with location:missing=false still matches. This suite uses three small, purpose-built PractitionerRole fixtures (one active with a location, one inactive with a location, one active with no location) scoped via _id so the :not/:missing behavior can be verified in both boolean directions and combined with an _id OR-list, going beyond the source test's single-direction coverage.",
  "status": "active",
  "fixture": [
    {
      "id": "practitioner-1",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Practitioner",
        "id": "fhir262-not-prac1",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/not-expr", "value": "not-expr-practitioner" }]
      }
    },
    {
      "id": "location-1",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Location",
        "id": "fhir262-not-loc1",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/not-expr", "value": "not-expr-location" }],
        "name": "Not-Expression Test Location"
      }
    },
    {
      "id": "pr-active",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "PractitionerRole",
        "id": "fhir262-not-pr-active",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/not-expr", "value": "not-expr-pr-active" }],
        "active": true,
        "practitioner": { "reference": "Practitioner/fhir262-not-prac1" },
        "location": [{ "reference": "Location/fhir262-not-loc1" }]
      }
    },
    {
      "id": "pr-inactive",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "PractitionerRole",
        "id": "fhir262-not-pr-inactive",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/not-expr", "value": "not-expr-pr-inactive" }],
        "active": false,
        "practitioner": { "reference": "Practitioner/fhir262-not-prac1" },
        "location": [{ "reference": "Location/fhir262-not-loc1" }]
      }
    },
    {
      "id": "pr-noloc",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "PractitionerRole",
        "id": "fhir262-not-pr-noloc",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/not-expr", "value": "not-expr-pr-noloc" }],
        "active": true,
        "practitioner": { "reference": "Practitioner/fhir262-not-prac1" }
      }
    }
  ],
  "setup": {
    "action": [
      { "operation": { "type": { "code": "update" }, "url": "Practitioner/fhir262-not-prac1", "sourceId": "practitioner-1", "description": "PUT Practitioner referenced by all PractitionerRole fixtures" } },
      { "operation": { "type": { "code": "update" }, "url": "Location/fhir262-not-loc1", "sourceId": "location-1", "description": "PUT Location referenced by pr-active and pr-inactive" } },
      { "operation": { "type": { "code": "update" }, "url": "PractitionerRole/fhir262-not-pr-active", "sourceId": "pr-active", "description": "PUT PractitionerRole: active=true, has a location" } },
      { "operation": { "type": { "code": "update" }, "url": "PractitionerRole/fhir262-not-pr-inactive", "sourceId": "pr-inactive", "description": "PUT PractitionerRole: active=false, has a location" } },
      { "operation": { "type": { "code": "update" }, "url": "PractitionerRole/fhir262-not-pr-noloc", "sourceId": "pr-noloc", "description": "PUT PractitionerRole: active=true, NO location" } }
    ]
  },
  "test": [
    {
      "name": "active:not=false matches a resource whose active value is true",
      "description": "PractitionerRole?_id=pr-active&active:not=false must match, because active:not=false excludes only resources whose active value literally equals false; pr-active's value is true so it passes the negation.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "PractitionerRole", "params": "?_id=fhir262-not-pr-active&active:not=false", "responseId": "not-false-active-response", "description": "GET /PractitionerRole?_id=fhir262-not-pr-active&active:not=false" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include pr-active", "expression": "entry.where(resource.id = 'fhir262-not-pr-active').exists()" } }
      ]
    },
    {
      "name": "active:not=false combined with location:missing=false still matches",
      "description": "Adding location:missing=false (pr-active has a location) must not change the result of the previous query: pr-active must still match.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "PractitionerRole", "params": "?_id=fhir262-not-pr-active&active:not=false&location:missing=false", "responseId": "not-false-loc-present-response", "description": "GET /PractitionerRole?_id=fhir262-not-pr-active&active:not=false&location:missing=false" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include pr-active", "expression": "entry.where(resource.id = 'fhir262-not-pr-active').exists()" } }
      ]
    },
    {
      "name": "active:not=true excludes a resource whose active value is true",
      "description": "PractitionerRole?_id=pr-active&active:not=true must return an empty result: pr-active's active value literally equals true, so :not=true filters it out.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "PractitionerRole", "params": "?_id=fhir262-not-pr-active&active:not=true", "responseId": "not-true-active-response", "description": "GET /PractitionerRole?_id=fhir262-not-pr-active&active:not=true" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must NOT include pr-active (its active value is true)", "expression": "entry.where(resource.id = 'fhir262-not-pr-active').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "active:not=true matches a resource whose active value is false (inverse direction)",
      "description": "PractitionerRole?_id=pr-inactive&active:not=true must match, because pr-inactive's active value is false, which does not equal true.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "PractitionerRole", "params": "?_id=fhir262-not-pr-inactive&active:not=true", "responseId": "not-true-inactive-response", "description": "GET /PractitionerRole?_id=fhir262-not-pr-inactive&active:not=true" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include pr-inactive", "expression": "entry.where(resource.id = 'fhir262-not-pr-inactive').exists()" } }
      ]
    },
    {
      "name": "active:not=false excludes a resource whose active value is false (inverse direction)",
      "description": "PractitionerRole?_id=pr-inactive&active:not=false must return an empty result: pr-inactive's active value literally equals false, so :not=false filters it out.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "PractitionerRole", "params": "?_id=fhir262-not-pr-inactive&active:not=false", "responseId": "not-false-inactive-response", "description": "GET /PractitionerRole?_id=fhir262-not-pr-inactive&active:not=false" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must NOT include pr-inactive (its active value is false)", "expression": "entry.where(resource.id = 'fhir262-not-pr-inactive').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "location:missing=true matches a resource with no location",
      "description": "PractitionerRole?_id=pr-noloc&location:missing=true must match, since pr-noloc has no location element.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "PractitionerRole", "params": "?_id=fhir262-not-pr-noloc&location:missing=true", "responseId": "missing-true-response", "description": "GET /PractitionerRole?_id=fhir262-not-pr-noloc&location:missing=true" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include pr-noloc", "expression": "entry.where(resource.id = 'fhir262-not-pr-noloc').exists()" } }
      ]
    },
    {
      "name": "location:missing=false excludes a resource with no location",
      "description": "PractitionerRole?_id=pr-noloc&location:missing=false must return an empty result, since pr-noloc has no location element to satisfy 'location present'.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "PractitionerRole", "params": "?_id=fhir262-not-pr-noloc&location:missing=false", "responseId": "missing-false-response", "description": "GET /PractitionerRole?_id=fhir262-not-pr-noloc&location:missing=false" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must NOT include pr-noloc", "expression": "entry.where(resource.id = 'fhir262-not-pr-noloc').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": ":not combined with an _id OR-list",
      "description": "PractitionerRole?_id=pr-active,pr-inactive&active:not=false must apply the :not filter across an _id OR-list: only pr-active (active=true) survives the negation; pr-inactive (active=false) is filtered out even though it matches the _id list.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "PractitionerRole", "params": "?_id=fhir262-not-pr-active,fhir262-not-pr-inactive&active:not=false", "responseId": "not-with-id-list-response", "description": "GET /PractitionerRole?_id=fhir262-not-pr-active,fhir262-not-pr-inactive&active:not=false" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include pr-active", "expression": "entry.where(resource.id = 'fhir262-not-pr-active').exists()" } },
        { "assert": { "description": "Must NOT include pr-inactive (filtered out by :not=false)", "expression": "entry.where(resource.id = 'fhir262-not-pr-inactive').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    }
  ],
  "teardown": {
    "action": [
      { "operation": { "type": { "code": "delete" }, "url": "PractitionerRole/fhir262-not-pr-active", "description": "Teardown: delete pr-active" } },
      { "operation": { "type": { "code": "delete" }, "url": "PractitionerRole/fhir262-not-pr-inactive", "description": "Teardown: delete pr-inactive" } },
      { "operation": { "type": { "code": "delete" }, "url": "PractitionerRole/fhir262-not-pr-noloc", "description": "Teardown: delete pr-noloc" } },
      { "operation": { "type": { "code": "delete" }, "url": "Location/fhir262-not-loc1", "description": "Teardown: delete Location" } },
      { "operation": { "type": { "code": "delete" }, "url": "Practitioner/fhir262-not-prac1", "description": "Teardown: delete Practitioner" } }
    ]
  }
}
