  "setup": {
    "action": [
      { "operation": { "type": { "code": "create" }, "resource": "Observation", "sourceId": "obs-0", "responseId": "create-obs-0", "description": "Create obs-0 (1979-12-31)" } },
      { "operation": { "type": { "code": "create" }, "resource": "Observation", "sourceId": "obs-1", "responseId": "create-obs-1", "description": "Create obs-1 (1980)" } },
      { "operation": { "type": { "code": "create" }, "resource": "Observation", "sourceId": "obs-2", "responseId": "create-obs-2", "description": "Create obs-2 (1980-05)" } },
      { "operation": { "type": { "code": "create" }, "resource": "Observation", "sourceId": "obs-3", "responseId": "create-obs-3", "description": "Create obs-3 (1980-05-11)" } },
      { "operation": { "type": { "code": "create" }, "resource": "Observation", "sourceId": "obs-4", "responseId": "create-obs-4", "description": "Create obs-4 (1980-05-11T16:32:15)" } },
      { "operation": { "type": { "code": "create" }, "resource": "Observation", "sourceId": "obs-5", "responseId": "create-obs-5", "description": "Create obs-5 (1980-05-11T16:32:15.500)" } },
      { "operation": { "type": { "code": "create" }, "resource": "Observation", "sourceId": "obs-6", "responseId": "create-obs-6", "description": "Create obs-6 (1981-01-01)" } },
      { "operation": { "type": { "code": "create" }, "resource": "Observation", "sourceId": "obs-7", "responseId": "create-obs-7", "description": "Create obs-7 (period 1980-05-16 to 1980-05-17)" } },
