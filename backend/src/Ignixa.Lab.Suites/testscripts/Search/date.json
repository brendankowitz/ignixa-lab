      { "operation": { "type": { "code": "create" }, "resource": "Patient", "sourceId": "patient-birth-day", "responseId": "create-patient-birth-day", "description": "Create patient born 2000-03-03" } },
      { "operation": { "type": { "code": "create" }, "resource": "Patient", "sourceId": "patient-birth-outside", "responseId": "create-patient-birth-outside", "description": "Create patient born 1999-12-31 (control)" } }
    ]
