  "test": [
    {
      "name": "AND of two repeated date params forms a range",
      "description": "date=gt1980-05-10&date=lt1980-05-12 ANDs the two bounds: only observations with end time after 1980-05-10 AND start time before 1980-05-12 match (obs-1 through obs-5). obs-0 (1979-12-31), obs-6 (1981-01-01) and obs-7 (period 1980-05-16..17) must be excluded.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code=fhir262-date-test&date=gt1980-05-10&date=lt1980-05-12", "responseId": "and-range-response", "description": "GET /Observation?date=gt1980-05-10&date=lt1980-05-12" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include obs-1 (1980)", "expression": "entry.where(resource.id = '${obs1Id}').exists()" } },
        { "assert": { "description": "Must include obs-2 (1980-05)", "expression": "entry.where(resource.id = '${obs2Id}').exists()" } },
        { "assert": { "description": "Must include obs-3 (1980-05-11)", "expression": "entry.where(resource.id = '${obs3Id}').exists()" } },
        { "assert": { "description": "Must include obs-4 (1980-05-11T16:32:15)", "expression": "entry.where(resource.id = '${obs4Id}').exists()" } },
        { "assert": { "description": "Must include obs-5 (1980-05-11T16:32:15.500)", "expression": "entry.where(resource.id = '${obs5Id}').exists()" } },
        { "assert": { "description": "Must NOT include obs-0 (1979-12-31)", "expression": "entry.where(resource.id = '${obs0Id}').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include obs-6 (1981-01-01)", "expression": "entry.where(resource.id = '${obs6Id}').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include obs-7 (period 1980-05-16..17)", "expression": "entry.where(resource.id = '${obs7Id}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "Date search matched against an effectivePeriod",
      "description": "date=1980-05-16T16:32:15.500 (a precise instant) must match any Observation whose range contains that instant: obs-1 (whole year 1980), obs-2 (whole month 1980-05), and obs-7 (period 1980-05-16 to 1980-05-17, containing it directly). Day/instant-precision May-11 observations (obs-3/4/5) do not contain a May-16 instant and must be excluded.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code=fhir262-date-test&date=1980-05-16T16:32:15.500", "responseId": "period-match-response", "description": "GET /Observation?date=1980-05-16T16:32:15.500" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include obs-1 (year 1980 contains the instant)", "expression": "entry.where(resource.id = '${obs1Id}').exists()" } },
        { "assert": { "description": "Must include obs-2 (month 1980-05 contains the instant)", "expression": "entry.where(resource.id = '${obs2Id}').exists()" } },
        { "assert": { "description": "Must include obs-7 (period directly contains the instant)", "expression": "entry.where(resource.id = '${obs7Id}').exists()" } },
        { "assert": { "description": "Must NOT include obs-3 (1980-05-11, a different day)", "expression": "entry.where(resource.id = '${obs3Id}').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include obs-4 (1980-05-11T16:32:15, a different instant)", "expression": "entry.where(resource.id = '${obs4Id}').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include obs-0 (1979-12-31)", "expression": "entry.where(resource.id = '${obs0Id}').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include obs-6 (1981-01-01)", "expression": "entry.where(resource.id = '${obs6Id}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "Invalid date search value returns 400",
      "description": "GET /Patient?birthdate=<value> with a syntactically invalid date value must be rejected with HTTP 400. Parametrized over '***' and '!' via the http://ignixa.io/testscript/parametrize engine extension.",
      "extension": [
        { "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" },
        {
          "url": "http://ignixa.io/testscript/parametrize",
          "extension": [
            { "url": "variable", "valueString": "invalidDate" },
            { "url": "values", "valueString": "***,!" }
          ]
        }
      ],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?birthdate=${invalidDate}", "description": "GET /Patient?birthdate=${invalidDate}" } },
        { "assert": { "description": "Server must return 400 Bad Request for a syntactically invalid date", "response": "bad" } }
      ]
    },
    {
      "name": "Out-of-range date value returns 400",
      "description": "GET /Patient?birthdate=<value> with a calendar-invalid date (Feb 30) or a dateTime with an excessive number of fractional-second digits must be rejected with HTTP 400. Parametrized via the http://ignixa.io/testscript/parametrize engine extension.",
      "extension": [
        { "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" },
        {
          "url": "http://ignixa.io/testscript/parametrize",
          "extension": [
            { "url": "variable", "valueString": "outOfRangeDate" },
            { "url": "values", "valueString": "1973-02-30,1973-02-28T01:01:09.999999999999999999" }
          ]
        }
      ],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?birthdate=${outOfRangeDate}", "description": "GET /Patient?birthdate=${outOfRangeDate}" } },
        { "assert": { "description": "Server must return 400 Bad Request for an out-of-range/malformed date", "response": "bad" } }
      ]
    },
    {
      "name": "Partial-precision date equality: exact match is unambiguous, cross-precision overlap is implementation-defined",
      "description": "birthdate=2000-03-03 (day precision) must match the patient born on exactly that day, and must NOT match the control patient born 1999-12-31 (clearly outside 2000) — both are true under any reading of the R4 date-equality prefix. Whether it ALSO matches coarser-precision patients born '2000-03' or '2000' is genuinely ambiguous: FHIR R4 defines eq as 'the range of the search value fully contains the range of the target value' (strict containment, which a day range does NOT satisfy against a month/year range), but Microsoft's shipped FHIR server default instead uses range-overlap semantics (tracked as a known deviation, AB#191826, with spec-compliant containment available behind an opt-in flag). Those two assertions are therefore warningOnly.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_id=${birthYearId},${birthMonthId},${birthDayId},${birthOutsideId}&birthdate=2000-03-03", "responseId": "partial-eq-response", "description": "GET /Patient?birthdate=2000-03-03 scoped to the four fixture patients" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include the exact day match (born 2000-03-03)", "expression": "entry.where(resource.id = '${birthDayId}').exists()" } },
        { "assert": { "description": "Must NOT include the control patient (born 1999-12-31, clearly outside 2000)", "expression": "entry.where(resource.id = '${birthOutsideId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "May include the month-precision patient (born 2000-03) — ambiguous: overlap vs. containment", "expression": "entry.where(resource.id = '${birthMonthId}').exists()", "warningOnly": true } },
        { "assert": { "description": "May include the year-precision patient (born 2000) — ambiguous: overlap vs. containment", "expression": "entry.where(resource.id = '${birthYearId}').exists()", "warningOnly": true } }
      ]
    }
  ],
  "teardown": {
    "action": [
      { "operation": { "type": { "code": "delete" }, "url": "Observation/${obs0Id}", "description": "Teardown: delete obs-0" } },
      { "operation": { "type": { "code": "delete" }, "url": "Observation/${obs1Id}", "description": "Teardown: delete obs-1" } },
      { "operation": { "type": { "code": "delete" }, "url": "Observation/${obs2Id}", "description": "Teardown: delete obs-2" } },
      { "operation": { "type": { "code": "delete" }, "url": "Observation/${obs3Id}", "description": "Teardown: delete obs-3" } },
      { "operation": { "type": { "code": "delete" }, "url": "Observation/${obs4Id}", "description": "Teardown: delete obs-4" } },
      { "operation": { "type": { "code": "delete" }, "url": "Observation/${obs5Id}", "description": "Teardown: delete obs-5" } },
      { "operation": { "type": { "code": "delete" }, "url": "Observation/${obs6Id}", "description": "Teardown: delete obs-6" } },
      { "operation": { "type": { "code": "delete" }, "url": "Observation/${obs7Id}", "description": "Teardown: delete obs-7" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/${birthYearId}", "description": "Teardown: delete patient born 2000" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/${birthMonthId}", "description": "Teardown: delete patient born 2000-03" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/${birthDayId}", "description": "Teardown: delete patient born 2000-03-03" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/${birthOutsideId}", "description": "Teardown: delete patient born 1999-12-31" } }
    ]
