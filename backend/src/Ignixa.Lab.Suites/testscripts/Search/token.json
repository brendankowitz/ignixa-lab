      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code=|code3&identifier=http://ignixa.io/testscript/suite/token|&_count=100", "responseId": "code-only-response", "description": "GET /Observation?code=|code3" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
