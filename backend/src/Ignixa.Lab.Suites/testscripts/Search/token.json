        { "assert": { "description": "Must include o6 (has code1 coding)", "expression": "entry.where(resource.id = 'fhir262-tok-o6').exists()" } },
        { "assert": { "description": "Must include o7 (has code1 coding)", "expression": "entry.where(resource.id = 'fhir262-tok-o7').exists()" } },
        { "assert": { "description": "Must NOT include o4 (code2 but wrong system)", "expression": "entry.where(resource.id = 'fhir262-tok-o4').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include o8 (code3, matches neither arm)", "expression": "entry.where(resource.id = 'fhir262-tok-o8').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "token: :text modifier matches 'free'",
      "description": "Observation?code:text=free searches CodeableConcept.text and Coding.display rather than the code itself. o3 (text='free text label'), o5 (display='free text label'), o6 (text='free text label') must match; o4/o7 (display='aux text label') must not.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
