        { "assert": { "description": "Must include o8 (code3, no system)", "expression": "entry.where(resource.id = 'fhir262-tok-o8').exists()" } },
        { "assert": { "description": "Must NOT include o5 (sysC|code3, has a system)", "expression": "entry.where(resource.id = 'fhir262-tok-o5').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include o7 (sysC|code3, has a system)", "expression": "entry.where(resource.id = 'fhir262-tok-o7').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
