        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include o3 (text label)", "expression": "entry.where(resource.id = 'fhir262-tok-o3').exists()" } },
        { "assert": { "description": "Must include o5 (display label)", "expression": "entry.where(resource.id = 'fhir262-tok-o5').exists()" } },
        { "assert": { "description": "Must include o6 (text label)", "expression": "entry.where(resource.id = 'fhir262-tok-o6').exists()" } },
        { "assert": { "description": "Must NOT include o4 ('aux text label')", "expression": "entry.where(resource.id = 'fhir262-tok-o4').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include o7 ('aux text label')", "expression": "entry.where(resource.id = 'fhir262-tok-o7').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
