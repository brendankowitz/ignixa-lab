      "description": "Observation?code:text=aux must match only the resources whose coding display starts with 'aux': o4 and o7. Must not match o3/o5/o6 which use the 'free text label' text/display.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
