  "test": [
    {
      "name": "token: system|code exact match",
      "description": "Observation?code=system|code must match resources whose coding has exactly that system AND code. o1 (sysA|code1) and o6 (also carries sysA|code1) must match; o2 (sysB|code2) and o4 (sysA|code2, wrong code) must not.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code=http://ignixa.io/testscript/suite/token-sys-a|code1&_count=100", "responseId": "sys-code-response", "description": "GET /Observation?code=http://ignixa.io/testscript/suite/token-sys-a|code1" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include o1", "expression": "entry.where(resource.id = 'fhir262-tok-o1').exists()" } },
        { "assert": { "description": "Must include o6 (also has sysA|code1 coding)", "expression": "entry.where(resource.id = 'fhir262-tok-o6').exists()" } },
        { "assert": { "description": "Must NOT include o2 (different system+code)", "expression": "entry.where(resource.id = 'fhir262-tok-o2').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include o4 (same system, different code)", "expression": "entry.where(resource.id = 'fhir262-tok-o4').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "token: system-only match (system|)",
      "description": "Observation?code=system| (trailing pipe, no code) must match any resource with a coding on that system regardless of code. o1, o4, o6 all carry a sysA coding and must match; o5 (sysC) must not.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code=http://ignixa.io/testscript/suite/token-sys-a|&_count=100", "responseId": "sys-only-response", "description": "GET /Observation?code=http://ignixa.io/testscript/suite/token-sys-a|" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include o1 (sysA|code1)", "expression": "entry.where(resource.id = 'fhir262-tok-o1').exists()" } },
        { "assert": { "description": "Must include o4 (sysA|code2)", "expression": "entry.where(resource.id = 'fhir262-tok-o4').exists()" } },
        { "assert": { "description": "Must include o6 (sysA|code1 coding)", "expression": "entry.where(resource.id = 'fhir262-tok-o6').exists()" } },
        { "assert": { "description": "Must NOT include o5 (sysC only)", "expression": "entry.where(resource.id = 'fhir262-tok-o5').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
