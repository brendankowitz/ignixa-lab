{
  "resourceType": "TestScript",
  "name": "Search/number",
  "description": "Number search-parameter prefix conformance tests on RiskAssessment.probability: implicit/eq default plus ne, lt, gt, le, ge, sa, and eb (from NumberSearchTests).",
  "status": "active",
  "fixture": [
    {
      "id": "subject",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "ignixa-num-subj",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/test", "value": "NUM-SUBJ" }]
      }
    },
    {
      "id": "ra-low",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "RiskAssessment",
        "id": "ignixa-num-low",
        "status": "final",
        "subject": { "reference": "Patient/ignixa-num-subj" },
        "meta": { "tag": [{ "system": "http://ignixa.io/testscript/suite/test", "code": "ignixa-num-suite" }] },
        "prediction": [{ "probabilityDecimal": 1 }]
      }
    },
    {
      "id": "ra-mid",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "RiskAssessment",
        "id": "ignixa-num-mid",
        "status": "final",
        "subject": { "reference": "Patient/ignixa-num-subj" },
        "meta": { "tag": [{ "system": "http://ignixa.io/testscript/suite/test", "code": "ignixa-num-suite" }] },
        "prediction": [{ "probabilityDecimal": 5 }]
      }
    },
    {
      "id": "ra-high",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "RiskAssessment",
        "id": "ignixa-num-high",
        "status": "final",
        "subject": { "reference": "Patient/ignixa-num-subj" },
        "meta": { "tag": [{ "system": "http://ignixa.io/testscript/suite/test", "code": "ignixa-num-suite" }] },
        "prediction": [{ "probabilityDecimal": 100 }]
      }
    }
  ],
  "setup": {
    "action": [
      { "operation": { "type": { "code": "update" }, "url": "Patient/ignixa-num-subj", "sourceId": "subject", "description": "PUT Patient/ignixa-num-subj — client-supplied ID so RiskAssessments can reference it" } },
      { "operation": { "type": { "code": "update" }, "url": "RiskAssessment/ignixa-num-low", "sourceId": "ra-low", "description": "PUT RiskAssessment/ignixa-num-low (probability=1)" } },
      { "operation": { "type": { "code": "update" }, "url": "RiskAssessment/ignixa-num-mid", "sourceId": "ra-mid", "description": "PUT RiskAssessment/ignixa-num-mid (probability=5)" } },
      { "operation": { "type": { "code": "update" }, "url": "RiskAssessment/ignixa-num-high", "sourceId": "ra-high", "description": "PUT RiskAssessment/ignixa-num-high (probability=100)" } }
    ]
  },
  "test": [
    {
      "name": "number: implicit (no prefix) and explicit eq are equivalent",
      "description": "RiskAssessment?probability=5 (implicit default) and ?probability=eq5 (explicit) must both match only the mid fixture (probability=5); low (1) and high (100) must not match.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "RiskAssessment", "params": "?probability=5&_tag=http://ignixa.io/testscript/suite/test|ignixa-num-suite&_count=100", "responseId": "num-implicit", "description": "GET RiskAssessment?probability=5 (implicit eq)" } },
        { "assert": { "description": "Implicit: HTTP 200", "response": "okay" } },
        { "assert": { "description": "Implicit: returns a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Implicit: must include mid (probability=5)", "expression": "entry.where(resource.id = 'ignixa-num-mid').exists()" } },
        { "assert": { "description": "Implicit: must NOT include low (probability=1)", "expression": "entry.where(resource.id = 'ignixa-num-low').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Implicit: must NOT include high (probability=100)", "expression": "entry.where(resource.id = 'ignixa-num-high').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "operation": { "type": { "code": "search" }, "resource": "RiskAssessment", "params": "?probability=eq5&_tag=http://ignixa.io/testscript/suite/test|ignixa-num-suite&_count=100", "responseId": "num-eq", "description": "GET RiskAssessment?probability=eq5 (explicit)" } },
        { "assert": { "description": "eq: HTTP 200", "response": "okay", "sourceId": "num-eq" } },
        { "assert": { "description": "eq: returns a Bundle", "resource": "Bundle", "sourceId": "num-eq" } },
        { "assert": { "description": "eq: must include mid (probability=5)", "expression": "entry.where(resource.id = 'ignixa-num-mid').exists()", "sourceId": "num-eq" } },
        { "assert": { "description": "eq: must NOT include low (probability=1)", "expression": "entry.where(resource.id = 'ignixa-num-low').exists()", "value": "false", "operator": "equals", "warningOnly": true, "sourceId": "num-eq" } },
        { "assert": { "description": "eq: must NOT include high (probability=100)", "expression": "entry.where(resource.id = 'ignixa-num-high').exists()", "value": "false", "operator": "equals", "warningOnly": true, "sourceId": "num-eq" } }
      ]
    },
    {
      "name": "number: ne — matches everything except the exact value",
      "description": "RiskAssessment?probability=ne5 must match low (1) and high (100); must not match mid (5).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "RiskAssessment", "params": "?probability=ne5&_tag=http://ignixa.io/testscript/suite/test|ignixa-num-suite&_count=100", "responseId": "num-ne", "description": "GET RiskAssessment?probability=ne5" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include low (1)", "expression": "entry.where(resource.id = 'ignixa-num-low').exists()" } },
        { "assert": { "description": "Must include high (100)", "expression": "entry.where(resource.id = 'ignixa-num-high').exists()" } },
        { "assert": { "description": "Must NOT include mid (5)", "expression": "entry.where(resource.id = 'ignixa-num-mid').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "number: lt — strictly less than",
      "description": "RiskAssessment?probability=lt5 must match only low (1); mid (5) and high (100) are not strictly less than 5.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "RiskAssessment", "params": "?probability=lt5&_tag=http://ignixa.io/testscript/suite/test|ignixa-num-suite&_count=100", "responseId": "num-lt", "description": "GET RiskAssessment?probability=lt5" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include low (1)", "expression": "entry.where(resource.id = 'ignixa-num-low').exists()" } },
        { "assert": { "description": "Must NOT include mid (5)", "expression": "entry.where(resource.id = 'ignixa-num-mid').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include high (100)", "expression": "entry.where(resource.id = 'ignixa-num-high').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "number: gt — strictly greater than",
      "description": "RiskAssessment?probability=gt5 must match only high (100); low (1) and mid (5) are not strictly greater than 5.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "RiskAssessment", "params": "?probability=gt5&_tag=http://ignixa.io/testscript/suite/test|ignixa-num-suite&_count=100", "responseId": "num-gt", "description": "GET RiskAssessment?probability=gt5" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include high (100)", "expression": "entry.where(resource.id = 'ignixa-num-high').exists()" } },
        { "assert": { "description": "Must NOT include low (1)", "expression": "entry.where(resource.id = 'ignixa-num-low').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include mid (5)", "expression": "entry.where(resource.id = 'ignixa-num-mid').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "number: le — less than or equal",
      "description": "RiskAssessment?probability=le5 must match low (1) and mid (5); high (100) is excluded.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "RiskAssessment", "params": "?probability=le5&_tag=http://ignixa.io/testscript/suite/test|ignixa-num-suite&_count=100", "responseId": "num-le", "description": "GET RiskAssessment?probability=le5" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include low (1)", "expression": "entry.where(resource.id = 'ignixa-num-low').exists()" } },
        { "assert": { "description": "Must include mid (5)", "expression": "entry.where(resource.id = 'ignixa-num-mid').exists()" } },
        { "assert": { "description": "Must NOT include high (100)", "expression": "entry.where(resource.id = 'ignixa-num-high').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "number: ge — greater than or equal",
      "description": "RiskAssessment?probability=ge5 must match mid (5) and high (100); low (1) is excluded.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "RiskAssessment", "params": "?probability=ge5&_tag=http://ignixa.io/testscript/suite/test|ignixa-num-suite&_count=100", "responseId": "num-ge", "description": "GET RiskAssessment?probability=ge5" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include mid (5)", "expression": "entry.where(resource.id = 'ignixa-num-mid').exists()" } },
        { "assert": { "description": "Must include high (100)", "expression": "entry.where(resource.id = 'ignixa-num-high').exists()" } },
        { "assert": { "description": "Must NOT include low (1)", "expression": "entry.where(resource.id = 'ignixa-num-low').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "number: sa (starts-after) — behaves like gt for point values",
      "description": "RiskAssessment?probability=sa5 must match only high (100), same result as gt5 since these fixtures are point decimals with no inherent range.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "RiskAssessment", "params": "?probability=sa5&_tag=http://ignixa.io/testscript/suite/test|ignixa-num-suite&_count=100", "responseId": "num-sa", "description": "GET RiskAssessment?probability=sa5" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include high (100)", "expression": "entry.where(resource.id = 'ignixa-num-high').exists()" } },
        { "assert": { "description": "Must NOT include mid (5)", "expression": "entry.where(resource.id = 'ignixa-num-mid').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include low (1)", "expression": "entry.where(resource.id = 'ignixa-num-low').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "number: eb (ends-before) — behaves like lt for point values",
      "description": "RiskAssessment?probability=eb5 must match only low (1), same result as lt5 since these fixtures are point decimals with no inherent range.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "RiskAssessment", "params": "?probability=eb5&_tag=http://ignixa.io/testscript/suite/test|ignixa-num-suite&_count=100", "responseId": "num-eb", "description": "GET RiskAssessment?probability=eb5" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include low (1)", "expression": "entry.where(resource.id = 'ignixa-num-low').exists()" } },
        { "assert": { "description": "Must NOT include mid (5)", "expression": "entry.where(resource.id = 'ignixa-num-mid').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include high (100)", "expression": "entry.where(resource.id = 'ignixa-num-high').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    }
  ],
  "teardown": {
    "action": [
      { "operation": { "type": { "code": "delete" }, "url": "RiskAssessment/ignixa-num-low", "description": "Teardown: delete ra-low" } },
      { "operation": { "type": { "code": "delete" }, "url": "RiskAssessment/ignixa-num-mid", "description": "Teardown: delete ra-mid" } },
      { "operation": { "type": { "code": "delete" }, "url": "RiskAssessment/ignixa-num-high", "description": "Teardown: delete ra-high" } },
      { "operation": { "type": { "code": "delete" }, "url": "Patient/ignixa-num-subj", "description": "Teardown: delete subject patient" } }
    ]
  }
