  "test": [
    {
      "name": "code-value-quantity: fully qualified system|code$prefix|value|system|unit",
      "description": "code-value-quantity ANDs a token (Observation.code) with a quantity (Observation.valueQuantity) on the SAME resource. http://snomed.info/sct|443849008$eq10|http://unitsofmeasure.org|{score} must match only obs-apgar20 (code 443849008, value 10 {score}).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code-value-quantity=http://snomed.info/sct|443849008$eq10|http://unitsofmeasure.org|%7Bscore%7D&identifier=http://ignixa.io/testscript/suite/composite|", "responseId": "cvq-full-response", "description": "GET /Observation?code-value-quantity=snomed|443849008$eq10|uom|%7Bscore%7D" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include obs-apgar20", "expression": "entry.where(resource.id = '${apgar20Id}').exists()" } },
        { "assert": { "description": "Must NOT include obs-apgar1 (value 0, not 10)", "expression": "entry.where(resource.id = '${apgar1Id}').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include obs-temperature (different code)", "expression": "entry.where(resource.id = '${temperatureId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "code-value-quantity: bare code and bare value (no systems)",
      "description": "code-value-quantity=443849008$10 (no system prefixes on either component) must still match obs-apgar20 by code+value alone.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code-value-quantity=443849008$10&identifier=http://ignixa.io/testscript/suite/composite|", "responseId": "cvq-bare-response", "description": "GET /Observation?code-value-quantity=443849008$10" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include obs-apgar20", "expression": "entry.where(resource.id = '${apgar20Id}').exists()" } }
      ]
    },
    {
      "name": "code-value-quantity: ne prefix excludes the exact-value match",
      "description": "code-value-quantity with the ne (not-equal) prefix on the quantity component must NOT match the observation whose value is exactly 10 (obs-apgar20).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code-value-quantity=http://snomed.info/sct|443849008$ne10|http://unitsofmeasure.org|%7Bscore%7D&identifier=http://ignixa.io/testscript/suite/composite|", "responseId": "cvq-ne-response", "description": "GET /Observation?code-value-quantity=snomed|443849008$ne10|uom|%7Bscore%7D" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must NOT include obs-apgar20 (value equals 10, ne excludes it)", "expression": "entry.where(resource.id = '${apgar20Id}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "code-value-quantity: unrelated quantity system does not match",
      "description": "code-value-quantity=unknownSystem|443849008$10 pairs the right code with a value-system that does not exist on obs-apgar20's valueQuantity, so it must not match.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code-value-quantity=unknownSystem|443849008$10&identifier=http://ignixa.io/testscript/suite/composite|", "responseId": "cvq-unknown-response", "description": "GET /Observation?code-value-quantity=unknownSystem|443849008$10" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must NOT include obs-apgar20 (code system does not match unknownSystem)", "expression": "entry.where(resource.id = '${apgar20Id}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "code-value-quantity: OR via comma matches two different observations",
      "description": "Comma-separated composite values are ORed. loinc|8310-5$39|uom|Cel,snomed|443849008$10|uom|{score} must match both obs-temperature and obs-apgar20.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code-value-quantity=http://loinc.org|8310-5$39|http://unitsofmeasure.org|Cel,http://snomed.info/sct|443849008$10|http://unitsofmeasure.org|%7Bscore%7D&identifier=http://ignixa.io/testscript/suite/composite|", "responseId": "cvq-or-response", "description": "GET /Observation?code-value-quantity=temperature OR apgar20" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include obs-temperature", "expression": "entry.where(resource.id = '${temperatureId}').exists()" } },
        { "assert": { "description": "Must include obs-apgar20", "expression": "entry.where(resource.id = '${apgar20Id}').exists()" } }
      ]
    },
    {
      "name": "code-value-quantity: mixed prefix OR",
      "description": "loinc|8310-5$gt36.6|uom|Cel (temperature above 36.6) OR loinc|9272-6$0|uom|{score} (1 minute Apgar value 0) must match obs-temperature (39 > 36.6) and obs-apgar1 (value 0).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code-value-quantity=http://loinc.org|8310-5$gt36.6|http://unitsofmeasure.org|Cel,http://loinc.org|9272-6$0|http://unitsofmeasure.org|%7Bscore%7D&identifier=http://ignixa.io/testscript/suite/composite|", "responseId": "cvq-mixed-response", "description": "GET /Observation?code-value-quantity=temperature>36.6 OR apgar1==0" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include obs-apgar1", "expression": "entry.where(resource.id = '${apgar1Id}').exists()" } },
        { "assert": { "description": "Must include obs-temperature", "expression": "entry.where(resource.id = '${temperatureId}').exists()" } }
      ]
    },
    {
      "name": "combo-code-value-quantity: matches when code and value come from the same component (systolic)",
      "description": "combo-code-value-quantity spans Observation | Observation.component, ANDing a token with a quantity from the SAME group. loinc|8480-6$107|uom|mm[Hg] must match obs-bloodpressure's component[0] (systolic code 8480-6 paired with value 107 mmHg).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?combo-code-value-quantity=http://loinc.org|8480-6$107|http://unitsofmeasure.org|mm%5BHg%5D&identifier=http://ignixa.io/testscript/suite/composite|", "responseId": "ccvq-systolic-response", "description": "GET /Observation?combo-code-value-quantity=8480-6$107|uom|mm[Hg] (brackets percent-encoded in the actual request)" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include obs-bloodpressure", "expression": "entry.where(resource.id = '${bloodPressureId}').exists()" } }
      ]
    },
    {
      "name": "combo-code-value-quantity: does not match code from one component paired with another component's value",
      "description": "combo-code-value-quantity must not match a code from one component paired with a value from a different component (systolic code with diastolic value).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?combo-code-value-quantity=http://loinc.org|8480-6$60&identifier=http://ignixa.io/testscript/suite/composite|", "responseId": "ccvq-crosscomponent-response", "description": "GET /Observation?combo-code-value-quantity=8480-6 (component[0].code)$60 (component[1].valueQuantity)" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must NOT include obs-bloodpressure (code and value are from different components)", "expression": "entry.where(resource.id = '${bloodPressureId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "code-value-string: fully qualified system|code$value exact match",
      "description": "code-value-string ANDs a token with a string. http://snomed.info/sct|162806009$blue must match only obs-eyecolor (valueString exactly 'blue'), not obs-longeyecolor.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code-value-string=http://snomed.info/sct|162806009$blue&identifier=http://ignixa.io/testscript/suite/composite|", "responseId": "cvs-exact-response", "description": "GET /Observation?code-value-string=snomed|162806009$blue" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include obs-eyecolor", "expression": "entry.where(resource.id = '${eyeColorId}').exists()" } },
        { "assert": { "description": "Must NOT include obs-longeyecolor", "expression": "entry.where(resource.id = '${longEyeColorId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "code-value-string: prefix (starts-with) match on a long string",
      "description": "The string component uses starts-with matching per the FHIR string search semantics. code-value-string=162806009$Lorem must match obs-longeyecolor (whose value starts with 'Lorem ipsum...'), not obs-eyecolor.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?code-value-string=162806009$Lorem&identifier=http://ignixa.io/testscript/suite/composite|", "responseId": "cvs-prefix-response", "description": "GET /Observation?code-value-string=162806009$Lorem" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include obs-longeyecolor", "expression": "entry.where(resource.id = '${longEyeColorId}').exists()" } },
        { "assert": { "description": "Must NOT include obs-eyecolor ('blue' does not start with 'Lorem')", "expression": "entry.where(resource.id = '${eyeColorId}').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "code-value-string: exact match on the full long string",
      "description": "code-value-string=162806009$<full Lorem ipsum text> must match obs-longeyecolor by exact string match, even though the value exceeds typical short-string lengths.",
