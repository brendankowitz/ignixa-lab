{
  "resourceType": "TestScript",
  "name": "Search/includes",
  "description": "_include / _revinclude / _include:iterate conformance tests ported from IncludeSearchTests.cs. Uses a small static graph: an Organization chain org-c <- org-b <- org-a (org-b.partOf=org-c, org-a.partOf=org-b) to exercise _include:iterate without needing a truly circular reference (a single iterate pass from _id=org-a should pull in org-b but NOT org-c); a separate Practitioner (prac1) and Organization (org) referenced by Patient pat1 (managingOrganization=org, generalPractitioner=prac1); an Observation (obs1, subject=pat1, performer=[prac1,org]) to test _include with no fixed target type; a DiagnosticReport (dr1, subject=pat1, result=[obs1], no specimen) for specimen:missing=true; and a self-referencing Location (loc-self, partOf=itself) to verify a resource matched by the search isn't duplicated as its own include. Uses client-supplied IDs (PUT) so cross-references resolve statically.",
  "status": "active",
  "fixture": [
    {
      "id": "org-c",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Organization",
        "id": "fhir262-inc-org-c",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/includes", "value": "INC-ORG-C" }],
        "name": "Include Test Org C (root)"
      }
    },
    {
      "id": "org-b",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Organization",
        "id": "fhir262-inc-org-b",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/includes", "value": "INC-ORG-B" }],
        "name": "Include Test Org B (middle)",
        "partOf": { "reference": "Organization/fhir262-inc-org-c" }
      }
    },
    {
      "id": "org-a",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Organization",
        "id": "fhir262-inc-org-a",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/includes", "value": "INC-ORG-A" }],
        "name": "Include Test Org A (leaf)",
        "partOf": { "reference": "Organization/fhir262-inc-org-b" }
      }
    },
    {
      "id": "org",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Organization",
        "id": "fhir262-inc-org",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/includes", "value": "INC-ORG" }],
        "name": "Include Test Managing Organization"
      }
    },
    {
      "id": "prac1",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Practitioner",
        "id": "fhir262-inc-prac1",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/includes", "value": "INC-PRAC1" }],
        "name": [{ "family": "IncludeTest", "given": ["Practitioner1"] }]
      }
    },
    {
      "id": "pat1",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Patient",
        "id": "fhir262-inc-pat1",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/includes", "value": "INC-PAT1" }],
        "name": [{ "family": "IncludeTest", "given": ["Patient1"] }],
        "managingOrganization": { "reference": "Organization/fhir262-inc-org" },
        "generalPractitioner": [{ "reference": "Practitioner/fhir262-inc-prac1" }]
      }
    },
    {
      "id": "obs1",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Observation",
        "id": "fhir262-inc-obs1",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/includes", "value": "INC-OBS1" }],
        "status": "final",
        "code": { "coding": [{ "system": "http://loinc.org", "code": "12345-6" }] },
        "subject": { "reference": "Patient/fhir262-inc-pat1" },
        "performer": [
          { "reference": "Practitioner/fhir262-inc-prac1" },
          { "reference": "Organization/fhir262-inc-org" }
        ]
      }
    },
    {
      "id": "dr1",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "DiagnosticReport",
        "id": "fhir262-inc-dr1",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/includes", "value": "INC-DR1" }],
        "status": "final",
        "code": { "coding": [{ "system": "http://loinc.org", "code": "24356-8" }] },
        "subject": { "reference": "Patient/fhir262-inc-pat1" },
        "result": [{ "reference": "Observation/fhir262-inc-obs1" }]
      }
    },
    {
      "id": "loc-self",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "resourceType": "Location",
        "id": "fhir262-inc-loc-self",
        "identifier": [{ "system": "http://ignixa.io/testscript/suite/includes", "value": "INC-LOC-SELF" }],
        "name": "Include Test Self-Referencing Location",
        "partOf": { "reference": "Location/fhir262-inc-loc-self" }
      }
    }
  ],
  "setup": {
    "action": [
      { "operation": { "type": { "code": "update" }, "url": "Organization/fhir262-inc-org-c", "sourceId": "org-c", "description": "PUT Organization/fhir262-inc-org-c (root, no partOf)" } },
      { "operation": { "type": { "code": "update" }, "url": "Organization/fhir262-inc-org-b", "sourceId": "org-b", "description": "PUT Organization/fhir262-inc-org-b (partOf org-c)" } },
      { "operation": { "type": { "code": "update" }, "url": "Organization/fhir262-inc-org-a", "sourceId": "org-a", "description": "PUT Organization/fhir262-inc-org-a (partOf org-b)" } },
      { "operation": { "type": { "code": "update" }, "url": "Organization/fhir262-inc-org", "sourceId": "org", "description": "PUT Organization/fhir262-inc-org (managing org)" } },
      { "operation": { "type": { "code": "update" }, "url": "Practitioner/fhir262-inc-prac1", "sourceId": "prac1", "description": "PUT Practitioner/fhir262-inc-prac1" } },
      { "operation": { "type": { "code": "update" }, "url": "Patient/fhir262-inc-pat1", "sourceId": "pat1", "description": "PUT Patient/fhir262-inc-pat1" } },
      { "operation": { "type": { "code": "update" }, "url": "Observation/fhir262-inc-obs1", "sourceId": "obs1", "description": "PUT Observation/fhir262-inc-obs1" } },
      { "operation": { "type": { "code": "update" }, "url": "DiagnosticReport/fhir262-inc-dr1", "sourceId": "dr1", "description": "PUT DiagnosticReport/fhir262-inc-dr1" } },
      { "operation": { "type": { "code": "update" }, "url": "Location/fhir262-inc-loc-self", "sourceId": "loc-self", "description": "PUT Location/fhir262-inc-loc-self (self-referencing partOf)" } }
    ]
  },
  "test": [
    {
      "name": "Forward _include pulls in the direct reference target",
      "description": "Patient?_id=pat1&_include=Patient:organization must return pat1 plus its managingOrganization (org) as an included resource.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_id=fhir262-inc-pat1&_include=Patient:organization", "responseId": "inc-forward", "description": "GET /Patient?_id=fhir262-inc-pat1&_include=Patient:organization" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include the matched patient", "expression": "entry.where(resource.id = 'fhir262-inc-pat1').exists()" } },
        { "assert": { "description": "Must include the managing organization", "expression": "entry.where(resource.id = 'fhir262-inc-org').exists()" } },
        { "assert": { "description": "Included organization entry must be marked as 'include'", "expression": "entry.where(resource.id = 'fhir262-inc-org').search.mode = 'include'" } }
      ]
    },
    {
      "name": "_include with no target type resolves references of any type",
      "description": "Observation?_id=obs1&_include=Observation:performer (no target type restriction) must include both performer types: Practitioner (prac1) and Organization (org).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?_id=fhir262-inc-obs1&_include=Observation:performer", "responseId": "inc-performer", "description": "GET /Observation?_id=fhir262-inc-obs1&_include=Observation:performer" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Must include the matched observation", "expression": "entry.where(resource.id = 'fhir262-inc-obs1').exists()" } },
        { "assert": { "description": "Must include the practitioner performer", "expression": "entry.where(resource.id = 'fhir262-inc-prac1').exists()" } },
        { "assert": { "description": "Must include the organization performer", "expression": "entry.where(resource.id = 'fhir262-inc-org').exists()" } }
      ]
    },
    {
      "name": "Wildcard _include=* pulls in every direct reference",
      "description": "Patient?_id=pat1&_include=* must include both managingOrganization (org) and generalPractitioner (prac1).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_id=fhir262-inc-pat1&_include=*", "responseId": "inc-wildcard", "description": "GET /Patient?_id=fhir262-inc-pat1&_include=*" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Must include managingOrganization", "expression": "entry.where(resource.id = 'fhir262-inc-org').exists()" } },
        { "assert": { "description": "Must include generalPractitioner", "expression": "entry.where(resource.id = 'fhir262-inc-prac1').exists()" } }
      ]
    },
    {
      "name": "Multiple _include params combine their targets",
      "description": "Patient?_id=pat1&_include=Patient:organization&_include=Patient:general-practitioner must include both org and prac1 in a single response.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_id=fhir262-inc-pat1&_include=Patient:organization&_include=Patient:general-practitioner", "responseId": "inc-multi", "description": "GET /Patient with two _include params" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Must include managingOrganization", "expression": "entry.where(resource.id = 'fhir262-inc-org').exists()" } },
        { "assert": { "description": "Must include generalPractitioner", "expression": "entry.where(resource.id = 'fhir262-inc-prac1').exists()" } }
      ]
    },
    {
      "name": "_revinclude pulls in resources that reference the match",
      "description": "Patient?_id=pat1&_revinclude=Observation:subject must return pat1 plus obs1 (which references pat1 as subject) as an included resource.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_id=fhir262-inc-pat1&_revinclude=Observation:subject", "responseId": "inc-revinclude", "description": "GET /Patient?_id=fhir262-inc-pat1&_revinclude=Observation:subject" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Must include the matched patient", "expression": "entry.where(resource.id = 'fhir262-inc-pat1').exists()" } },
        { "assert": { "description": "Must include the referencing observation", "expression": "entry.where(resource.id = 'fhir262-inc-obs1').exists()" } },
        { "assert": { "description": "Included observation entry must be marked as 'include'", "expression": "entry.where(resource.id = 'fhir262-inc-obs1').search.mode = 'include'" } }
      ]
    },
    {
      "name": "Wildcard _revinclude=* pulls in every referencing resource type",
      "description": "Patient?_id=pat1&_revinclude=* must include both obs1 (Observation.subject) and dr1 (DiagnosticReport.subject).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_id=fhir262-inc-pat1&_revinclude=*", "responseId": "inc-revinclude-wildcard", "description": "GET /Patient?_id=fhir262-inc-pat1&_revinclude=*" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Must include obs1", "expression": "entry.where(resource.id = 'fhir262-inc-obs1').exists()" } },
        { "assert": { "description": "Must include dr1", "expression": "entry.where(resource.id = 'fhir262-inc-dr1').exists()" } }
      ]
    },
    {
      "name": "_include:iterate follows a second hop through the included resource",
      "description": "Observation?_id=obs1&_include=Observation:subject&_include:iterate=Patient:organization must include pat1 (direct) and then org (iterated hop from pat1.managingOrganization).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?_id=fhir262-inc-obs1&_include=Observation:subject&_include:iterate=Patient:organization", "responseId": "inc-iterate-hop", "description": "GET /Observation with _include + _include:iterate two-hop" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Must include obs1", "expression": "entry.where(resource.id = 'fhir262-inc-obs1').exists()" } },
        { "assert": { "description": "Must include pat1 (direct include)", "expression": "entry.where(resource.id = 'fhir262-inc-pat1').exists()" } },
        { "assert": { "description": "Must include org (iterated include via pat1.managingOrganization)", "expression": "entry.where(resource.id = 'fhir262-inc-org').exists()" } }
      ]
    },
    {
      "name": "_include:iterate wildcard target follows any reference type on the included resource",
      "description": "Observation?_id=obs1&_include=Observation:subject&_include:iterate=Patient:general-practitioner must include pat1 (direct) and then prac1 (iterated hop from pat1.generalPractitioner).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Observation", "params": "?_id=fhir262-inc-obs1&_include=Observation:subject&_include:iterate=Patient:general-practitioner", "responseId": "inc-iterate-gp", "description": "GET /Observation with _include:iterate on generalPractitioner" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Must include pat1", "expression": "entry.where(resource.id = 'fhir262-inc-pat1').exists()" } },
        { "assert": { "description": "Must include prac1 (iterated hop)", "expression": "entry.where(resource.id = 'fhir262-inc-prac1').exists()" } }
      ]
    },
    {
      "name": "_include:iterate on a same-type chain performs a single iteration, not unbounded recursion",
      "description": "Organization?_id=org-a&_include:iterate=Organization:partof must include org-b (org-a.partOf) after one iteration, but must NOT include org-c (org-b.partOf), since _include:iterate performs exactly one additional hop per occurrence, not a full transitive closure. This mirrors the intent of the source test's circular-reference scenario (structurally repeating source/target types) without requiring an actual reference cycle.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Organization", "params": "?_id=fhir262-inc-org-a&_include:iterate=Organization:partof", "responseId": "inc-iterate-chain", "description": "GET /Organization?_id=fhir262-inc-org-a&_include:iterate=Organization:partof" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Must include org-a (matched)", "expression": "entry.where(resource.id = 'fhir262-inc-org-a').exists()" } },
        { "assert": { "description": "Must include org-b (one iteration of partof)", "expression": "entry.where(resource.id = 'fhir262-inc-org-b').exists()" } },
        { "assert": { "description": "Should NOT include org-c (would require a second iteration); behavior may vary by server", "expression": "entry.where(resource.id = 'fhir262-inc-org-c').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "Matched-resource filters (_id) are not applied to the included resources",
      "description": "Patient?_id=pat1&_include=Patient:organization must still include org even though org itself does not satisfy the _id=pat1 predicate -- the predicate only restricts the matched set, not the included set.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_id=fhir262-inc-pat1&_include=Patient:organization", "responseId": "inc-id-not-applied", "description": "GET /Patient?_id=fhir262-inc-pat1&_include=Patient:organization" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Included org must be present despite not matching _id=pat1", "expression": "entry.where(resource.id = 'fhir262-inc-org').exists()" } }
      ]
    },
    {
      "name": "specimen:missing=true combined with _include still includes the referenced resource",
      "description": "DiagnosticReport?specimen:missing=true&_id=dr1&_include=DiagnosticReport:result must match dr1 (no specimen) and include obs1 (result reference).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "DiagnosticReport", "params": "?specimen:missing=true&_id=fhir262-inc-dr1&_include=DiagnosticReport:result", "responseId": "inc-specimen-missing", "description": "GET /DiagnosticReport?specimen:missing=true&_id=fhir262-inc-dr1&_include=DiagnosticReport:result" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Must match dr1 (no specimen)", "expression": "entry.where(resource.id = 'fhir262-inc-dr1').exists()" } },
        { "assert": { "description": "Must include obs1 (result reference)", "expression": "entry.where(resource.id = 'fhir262-inc-obs1').exists()" } }
      ]
    },
    {
      "name": "A self-referencing partOf does not duplicate the matched resource as its own include",
      "description": "Location?_id=loc-self&_include=Location:partof matches loc-self, whose partOf points at itself; the response must contain exactly one entry for loc-self (not a separate 'matched' entry plus a duplicate 'include' entry).",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Location", "params": "?_id=fhir262-inc-loc-self&_include=Location:partof", "responseId": "inc-self-ref", "description": "GET /Location?_id=fhir262-inc-loc-self&_include=Location:partof" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Must include loc-self exactly once", "expression": "entry.where(resource.id = 'fhir262-inc-loc-self').count() = 1" } }
      ]
    },
    {
      "name": "_summary=count excludes included resources from the reported total",
      "description": "Patient?_id=pat1&_include=Patient:organization&_summary=count must return total=1 (only the matched patient counts, not the included organization) and an empty entry list.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_id=fhir262-inc-pat1&_include=Patient:organization&_summary=count", "responseId": "inc-summary-count", "description": "GET /Patient?_id=fhir262-inc-pat1&_include=Patient:organization&_summary=count" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Entry list must be empty", "expression": "entry.count() = 0" } },
        { "assert": { "description": "total must be exactly 1", "expression": "total = 1" } }
      ]
    },
    {
      "name": "_total=accurate excludes included resources from the reported total",
      "description": "Patient?_id=pat1&_include=Patient:organization&_total=accurate must return total=1 (matched patient only) while still including org in the entry list.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_id=fhir262-inc-pat1&_include=Patient:organization&_total=accurate", "responseId": "inc-total-accurate", "description": "GET /Patient?_id=fhir262-inc-pat1&_include=Patient:organization&_total=accurate" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "total must be exactly 1", "expression": "total = 1" } },
        { "assert": { "description": "Included org must still be present in the entry list", "expression": "entry.where(resource.id = 'fhir262-inc-org').exists()" } }
      ]
    },
    {
      "name": "Invalid target resource type on _include returns a Bad Request",
      "description": "Patient?_id=pat1&_include=Patient:organization:NotAResourceType (invalid target type) must return HTTP 400 with an OperationOutcome error.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_id=fhir262-inc-pat1&_include=Patient:organization:NotAResourceType", "responseId": "inc-invalid-target", "description": "GET /Patient?_id=fhir262-inc-pat1&_include=Patient:organization:NotAResourceType" } },
        { "assert": { "description": "Search must return HTTP 400 Bad Request", "response": "bad" } },
        { "assert": { "description": "Response must be an OperationOutcome error", "expression": "OperationOutcome.issue.where(severity = 'error' or severity = 'fatal').exists()" } }
      ]
    },
    {
      "name": "_include and _revinclude combine in a single request",
      "description": "Patient?_id=pat1&_include=Patient:organization&_revinclude=Observation:subject must include both org (forward include) and obs1 (reverse include) alongside the matched patient, exercising the combined-query-plan path.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "Patient", "params": "?_id=fhir262-inc-pat1&_include=Patient:organization&_revinclude=Observation:subject", "responseId": "inc-combined", "description": "GET /Patient with both _include and _revinclude" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Must include pat1", "expression": "entry.where(resource.id = 'fhir262-inc-pat1').exists()" } },
        { "assert": { "description": "Must include org (forward include)", "expression": "entry.where(resource.id = 'fhir262-inc-org').exists()" } },
        { "assert": { "description": "Must include obs1 (reverse include)", "expression": "entry.where(resource.id = 'fhir262-inc-obs1').exists()" } }
      ]
    }
  ],
