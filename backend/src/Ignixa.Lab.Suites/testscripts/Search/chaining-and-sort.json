  "test": [
    {
      "name": "Reverse chain: HealthcareServices linked to the target practitioner",
      "description": "HealthcareService?_has:PractitionerRole:service:practitioner=fhir262-cs-prac-target must return hs1..hs5 (all have a PractitionerRole for prac-target); hsdecoy (linked only to prac-other) must not appear.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "HealthcareService", "params": "?_has:PractitionerRole:service:practitioner=fhir262-cs-prac-target&identifier=http://ignixa.io/testscript/suite/chaining-and-sort|&_count=100", "responseId": "chain-only", "description": "GET /HealthcareService?_has:PractitionerRole:service:practitioner=fhir262-cs-prac-target" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include hs1", "expression": "entry.where(resource.id = 'fhir262-cs-hs1').exists()" } },
        { "assert": { "description": "Must include hs2", "expression": "entry.where(resource.id = 'fhir262-cs-hs2').exists()" } },
        { "assert": { "description": "Must include hs3", "expression": "entry.where(resource.id = 'fhir262-cs-hs3').exists()" } },
        { "assert": { "description": "Must include hs4", "expression": "entry.where(resource.id = 'fhir262-cs-hs4').exists()" } },
        { "assert": { "description": "Must include hs5", "expression": "entry.where(resource.id = 'fhir262-cs-hs5').exists()" } },
        { "assert": { "description": "Must NOT include hsdecoy (linked only to prac-other)", "expression": "entry.where(resource.id = 'fhir262-cs-hsdecoy').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "Chain + active:not=false excludes the inactive service",
      "description": "Adding active:not=false to the reverse chain excludes hs3 (active=false); hs1,hs2,hs4,hs5 (all active=true) remain.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "HealthcareService", "params": "?_has:PractitionerRole:service:practitioner=fhir262-cs-prac-target&active:not=false&identifier=http://ignixa.io/testscript/suite/chaining-and-sort|&_count=100", "responseId": "chain-active-not", "description": "GET .../HealthcareService?..._has...&active:not=false" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include hs1", "expression": "entry.where(resource.id = 'fhir262-cs-hs1').exists()" } },
        { "assert": { "description": "Must include hs2", "expression": "entry.where(resource.id = 'fhir262-cs-hs2').exists()" } },
        { "assert": { "description": "Must include hs4", "expression": "entry.where(resource.id = 'fhir262-cs-hs4').exists()" } },
        { "assert": { "description": "Must include hs5", "expression": "entry.where(resource.id = 'fhir262-cs-hs5').exists()" } },
        { "assert": { "description": "Must NOT include hs3 (active=false)", "expression": "entry.where(resource.id = 'fhir262-cs-hs3').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "Chain + name:missing=false excludes the unnamed service",
      "description": "Adding name:missing=false to the reverse chain excludes hs2 (no name); hs1,hs3,hs4,hs5 (all named) remain.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "HealthcareService", "params": "?_has:PractitionerRole:service:practitioner=fhir262-cs-prac-target&name:missing=false&identifier=http://ignixa.io/testscript/suite/chaining-and-sort|&_count=100", "responseId": "chain-name-missing", "description": "GET .../HealthcareService?..._has...&name:missing=false" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include hs1", "expression": "entry.where(resource.id = 'fhir262-cs-hs1').exists()" } },
        { "assert": { "description": "Must include hs3", "expression": "entry.where(resource.id = 'fhir262-cs-hs3').exists()" } },
        { "assert": { "description": "Must include hs4", "expression": "entry.where(resource.id = 'fhir262-cs-hs4').exists()" } },
        { "assert": { "description": "Must include hs5", "expression": "entry.where(resource.id = 'fhir262-cs-hs5').exists()" } },
        { "assert": { "description": "Must NOT include hs2 (no name)", "expression": "entry.where(resource.id = 'fhir262-cs-hs2').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "Chain + location:missing=false excludes the service without a location",
      "description": "Adding location:missing=false to the reverse chain excludes hs4 (no location); hs1,hs2,hs3,hs5 (all located) remain.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "HealthcareService", "params": "?_has:PractitionerRole:service:practitioner=fhir262-cs-prac-target&location:missing=false&identifier=http://ignixa.io/testscript/suite/chaining-and-sort|&_count=100", "responseId": "chain-location-missing", "description": "GET .../HealthcareService?..._has...&location:missing=false" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include hs1", "expression": "entry.where(resource.id = 'fhir262-cs-hs1').exists()" } },
        { "assert": { "description": "Must include hs2", "expression": "entry.where(resource.id = 'fhir262-cs-hs2').exists()" } },
        { "assert": { "description": "Must include hs3", "expression": "entry.where(resource.id = 'fhir262-cs-hs3').exists()" } },
        { "assert": { "description": "Must include hs5", "expression": "entry.where(resource.id = 'fhir262-cs-hs5').exists()" } },
        { "assert": { "description": "Must NOT include hs4 (no location)", "expression": "entry.where(resource.id = 'fhir262-cs-hs4').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "Second _has excludes the service whose only role is inactive",
      "description": "Adding a second reverse chain, _has:PractitionerRole:service:active=true, requires the linking PractitionerRole itself to be active. hs5's only role (role5) is inactive, so hs5 is excluded even though hs5.active=true; hs1..hs4 (each linked by an active role) remain.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "HealthcareService", "params": "?_has:PractitionerRole:service:practitioner=fhir262-cs-prac-target&_has:PractitionerRole:service:active=true&identifier=http://ignixa.io/testscript/suite/chaining-and-sort|&_count=100", "responseId": "chain-role-active", "description": "GET .../HealthcareService with two _has clauses (practitioner + role active=true)" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include hs1", "expression": "entry.where(resource.id = 'fhir262-cs-hs1').exists()" } },
        { "assert": { "description": "Must include hs2", "expression": "entry.where(resource.id = 'fhir262-cs-hs2').exists()" } },
        { "assert": { "description": "Must include hs3", "expression": "entry.where(resource.id = 'fhir262-cs-hs3').exists()" } },
        { "assert": { "description": "Must include hs4", "expression": "entry.where(resource.id = 'fhir262-cs-hs4').exists()" } },
        { "assert": { "description": "Must NOT include hs5 (its only PractitionerRole, role5, is inactive)", "expression": "entry.where(resource.id = 'fhir262-cs-hs5').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "Combined chain + all modifiers narrows to exactly one match",
      "description": "Combining the reverse chain with active:not=false, name:missing=false, location:missing=false and the second _has:PractitionerRole:service:active=true (mirroring ChainingAndSortTests.cs's commonQuery) narrows the result to exactly hs1, the only service passing every filter.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "HealthcareService", "params": "?_has:PractitionerRole:service:practitioner=fhir262-cs-prac-target&active:not=false&name:missing=false&location:missing=false&_has:PractitionerRole:service:active=true&identifier=http://ignixa.io/testscript/suite/chaining-and-sort|&_count=100", "responseId": "chain-combined", "description": "GET .../HealthcareService with the full combined filter set" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Must include hs1 (passes every filter)", "expression": "entry.where(resource.id = 'fhir262-cs-hs1').exists()" } },
        { "assert": { "description": "Must NOT include hs2 (no name)", "expression": "entry.where(resource.id = 'fhir262-cs-hs2').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include hs3 (inactive)", "expression": "entry.where(resource.id = 'fhir262-cs-hs3').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include hs4 (no location)", "expression": "entry.where(resource.id = 'fhir262-cs-hs4').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include hs5 (only role is inactive)", "expression": "entry.where(resource.id = 'fhir262-cs-hs5').exists()", "value": "false", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Must NOT include hsdecoy (different practitioner)", "expression": "entry.where(resource.id = 'fhir262-cs-hsdecoy').exists()", "value": "false", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "_sort=name orders chained results ascending (missing name last)",
      "description": "Applying _sort=name to the base reverse-chain query (hs1..hs5) should order by name ascending: hs1 (Alpha), hs4 (Delta), hs5 (Epsilon), hs3 (Gamma), then hs2 (no name) last. Position assertions are warningOnly since null-ordering conventions vary across servers.",
      "extension": [{ "url": "http://ignixa.io/testscript/fhirVersions", "valueString": "4.0,4.3,5.0" }],
      "action": [
        { "operation": { "type": { "code": "search" }, "resource": "HealthcareService", "params": "?_has:PractitionerRole:service:practitioner=fhir262-cs-prac-target&identifier=http://ignixa.io/testscript/suite/chaining-and-sort|&_count=100&_sort=name", "responseId": "chain-sort-name", "description": "GET .../HealthcareService?..._has...&_sort=name" } },
        { "assert": { "description": "Search must return HTTP 200", "response": "okay" } },
        { "assert": { "description": "Response must be a Bundle", "resource": "Bundle" } },
        { "assert": { "description": "Position 0 should be hs1 (Alpha Clinic)", "expression": "entry[0].resource.id", "value": "fhir262-cs-hs1", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Position 1 should be hs4 (Delta Clinic)", "expression": "entry[1].resource.id", "value": "fhir262-cs-hs4", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Position 2 should be hs5 (Epsilon Clinic)", "expression": "entry[2].resource.id", "value": "fhir262-cs-hs5", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Position 3 should be hs3 (Gamma Clinic)", "expression": "entry[3].resource.id", "value": "fhir262-cs-hs3", "operator": "equals", "warningOnly": true } },
        { "assert": { "description": "Position 4 should be hs2 (no name, sorts last)", "expression": "entry[4].resource.id", "value": "fhir262-cs-hs2", "operator": "equals", "warningOnly": true } }
      ]
    },
    {
      "name": "_summary=count on the combined query reports the total without returning entries",
      "description": "Adding _summary=count to the fully-combined query (which matches exactly hs1) must return an empty entry list and Bundle.total=1.",
