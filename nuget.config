<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <!-- Keep fixed-version local development packages isolated per repository. -->
    <add key="globalPackagesFolder" value="artifacts/nuget-packages" />
  </config>
  <packageSources>
    <clear />
    <!--
      Interim local feed for the IgnixaLab.TestScript.Suites content package
      (ADR-2607). Populated by backend/pack-suites.ps1 before restore; retire
      once ignixa-fhir publishes the suites artifact to nuget.org.
    -->
    <add key="local-feed" value="artifacts/local-feed" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
